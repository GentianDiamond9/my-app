datasource db {
  provider = "postgresql"
  adapter  = "postgresql" // url ではなく、必ずこれだけにします
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  deadline     DateTime
  importance   Int
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("tasks")
}