datasource db {
  provider = "postgresql" // もし SQLite や MySQL を使う場合はここを変更します
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  deadline     DateTime
  importance   Int
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("tasks") // データベース上のテーブル名をスネークケースにマッピング
}