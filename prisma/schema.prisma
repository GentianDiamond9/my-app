datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // 従来の指定方法
}

generator client {
  provider = "prisma-client-js"
  // 一部のビルド環境のバグを回避するため、明示的にドライバーアダプターを適用させない指定（標準構成）にします
  previewFeatures = [] 
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  deadline     DateTime
  importance   Int
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("tasks")
}