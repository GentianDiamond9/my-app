datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String
  deadline     DateTime  // 分単位の指定もそのままDateTimeで保持されます
  importance   Int
  is_completed Boolean   @default(false)
  created_at   DateTime  @default(now())
  completed_at DateTime? // 完了ボタンが押された日時を記録するオプショナルフィールド
  tag          String?
  color        String?

  @@map("tasks")
}