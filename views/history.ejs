<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Task - 過去の歴史</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #0b0f19;
        --card-bg: #111827;
        --text: #f9fafb;
        --text-muted: #9ca3af;
        --border: #374151;
      }
      [data-theme="light"] {
        --bg: #f3f4f6;
        --card-bg: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
          background-color 0.3s,
          color 0.3s;
      }

      .btn {
        transition: all 0.2s ease;
        border-radius: 8px;
      }
      .btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
      }

      #historyCanvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: auto;
      }

      .overlay-ui {
        position: relative;
        z-index: 10;
        pointer-events: none;
      }
      .interactive-element {
        pointer-events: auto;
      }
    </style>
  </head>
  <body>
    <canvas id="historyCanvas"></canvas>

    <div class="overlay-ui flex flex-col h-full justify-between p-6">
      <header
        class="flex justify-between items-center bg-slate-900/80 backdrop-blur-md p-4 rounded-2xl border border-slate-700/50 interactive-element"
      >
        <div>
          <h1
            class="text-2xl font-black tracking-tight text-white flex items-center gap-2"
          >
            🌌 過去の歴史 (Shattered Universe)
          </h1>
          <p class="text-xs text-slate-400 mt-0.5">
            あなたが今までにこなしたタスクたちです。
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/"
            class="btn px-4 py-2 bg-slate-800 text-white font-bold text-sm border border-slate-700"
          >
            ↩ タスク盤面に戻る
          </a>
          <button
            id="themeToggle"
            class="btn p-2 bg-slate-800 text-lg border border-slate-700"
          >
            🌓
          </button>
        </div>
      </header>

      <footer
        class="bg-slate-900/80 backdrop-blur-md p-3 rounded-xl border border-slate-700/50 flex justify-between items-center interactive-element text-xs text-slate-400"
      >
        <span>🚀 観測中のかけら: <strong><%= tasks.length %></strong> 個</span>
        <span
          >💡
          マウスカーソルが近づいた破片だけが物理的に反応し、移動・回転します（超軽量設計）</span
        >
      </footer>
    </div>
    <script>
      const completedTasks = <%- JSON.stringify(tasks) %>;

      // テーマ切り替え
      if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      document.getElementById('themeToggle').addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          if (currentTheme === 'dark') {
              document.documentElement.removeAttribute('data-theme');
              localStorage.setItem('theme', 'light');
          } else {
              document.documentElement.setAttribute('data-theme', 'dark');
              localStorage.setItem('theme', 'dark');
          }
      });

      const canvas = document.getElementById('historyCanvas');
      const ctx = canvas.getContext('2d');
      let width = canvas.width = window.innerWidth;
      let height = canvas.height = window.innerHeight;
      window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
      });

      // マウス位置 (初期位置は衝突しないよう画面外)
      const mouse = { x: -1000, y: -1000, radius: 200 };
      window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;
      });
      window.addEventListener('mouseleave', () => {
          mouse.x = -1000;
          mouse.y = -1000;
      });

      // 🔥 【対策A】Intlを用いた日本時間タイムゾーンでの日付取得
      function formatToJST(dateString) {
          if (!dateString) return "-";
          const d = new Date(dateString);
          const formatter = new Intl.DateTimeFormat('ja-JP', {
              timeZone: 'Asia/Tokyo',
              year: 'numeric',
              month: '2-digit',
              day: '2-digit'
          });
          return formatter.format(d);
      }

      // 破片 (Fragment) クラス
      class Fragment {
          constructor(task) {
              this.title = task.title;
              this.tag = task.tag || "なし";
              this.deadline = new Date(task.deadline);
              this.deadlineStr = formatToJST(task.deadline); // 日本時間同期
              this.color = task.color || "#6366f1";
              this.importance = Number(task.importance) || 1;

              // 画面全体にランダムに配置
              this.x = Math.random() * (width - 300) + 150;
              this.y = Math.random() * (height - 300) + 150;

              // 重要度の面積比例
              const baseRadius = 60;
              const scaleFactor = Math.sqrt(this.importance);
              this.radius = baseRadius * scaleFactor;

              this.sizeW = this.radius * 2 * 1.1;
              this.sizeH = this.radius * 2 * 0.85;

              // 多角形頂点
              this.vertices = [];
              const numPoints = 6 + Math.floor(Math.random() * 3);
              for (let i = 0; i < numPoints; i++) {
                  const angle = (i / numPoints) * Math.PI * 2;
                  const offsetRadius = 0.8 + Math.random() * 0.3;
                  this.vertices.push({
                      x: Math.cos(angle) * (this.sizeW / 2) * offsetRadius,
                      y: Math.sin(angle) * (this.sizeH / 2) * offsetRadius
                  });
              }

              // 回転初期化
              this.angle = Math.random() * Math.PI * 2;
              this.vx = 0;
              this.vy = 0;
              this.currentRotationSpeed = 0;

              // 文字列幅の事前パース（ボトルネック解消）
              const fontBase = this.radius * 0.16;
              ctx.font = `bold ${Math.max(10, fontBase)}px sans-serif`;
              const maxW = this.sizeW * 0.75;
              let displayTitle = this.title;
              if (ctx.measureText(displayTitle).width > maxW) {
                  while (ctx.measureText(displayTitle + "...").width > maxW && displayTitle.length > 0) {
                      displayTitle = displayTitle.slice(0, -1);
                  }
                  displayTitle += "...";
              }
              this.displayTitle = displayTitle;
          }

          update() {
              const dx = this.x - mouse.x;
              const dy = this.y - mouse.y;
              const dist = Math.sqrt(dx * dx + dy * dy);

              // 🌟 【超軽量化の鍵】マウスが影響範囲 (mouse.radius) の中にいる時だけ物理演算を動かす
              if (dist < mouse.radius) {
                  const force = (mouse.radius - dist) / mouse.radius;
                  const repelAngle = Math.atan2(dy, dx);

                  // 反発速度の加算
                  this.vx += Math.cos(repelAngle) * force * 2.2;
                  this.vy += Math.sin(repelAngle) * force * 2.2;

                  // 微妙なスピン（回転）を与える
                  const spinDirection = (dx > 0 ? 1 : -1);
                  this.currentRotationSpeed += spinDirection * force * 0.012;
              } else {
                  // 範囲外なら、摩擦減速（イージング）を強くかけ、一瞬で完全静止（速度・回転 = 0）させる
                  this.vx *= 0.82;
                  this.vy *= 0.82;
                  this.currentRotationSpeed *= 0.82;

                  if (Math.abs(this.vx) < 0.05) this.vx = 0;
                  if (Math.abs(this.vy) < 0.05) this.vy = 0;
                  if (Math.abs(this.currentRotationSpeed) < 0.001) this.currentRotationSpeed = 0;
              }

              // 最高速度制限
              const maxSpeed = 5;
              const currentSpeed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
              if (currentSpeed > maxSpeed) {
                  this.vx = (this.vx / currentSpeed) * maxSpeed;
                  this.vy = (this.vy / currentSpeed) * maxSpeed;
              }

              // 実際に座標を加算
              this.x += this.vx;
              this.y += this.vy;
              this.angle += this.currentRotationSpeed;

              // 画面端の境界線衝突処理
              const boundR = this.radius;
              if (this.x - boundR < 0) {
                  this.x = boundR;
                  this.vx *= -0.5;
              } else if (this.x + boundR > width) {
                  this.x = width - boundR;
                  this.vx *= -0.5;
              }

              if (this.y - boundR < 0) {
                  this.y = boundR;
                  this.vy *= -0.5;
              } else if (this.y + boundR > height) {
                  this.y = height - boundR;
                  this.vy *= -0.5;
              }
          }

          draw() {
              ctx.save();
              ctx.translate(this.x, this.y);
              ctx.rotate(this.angle);

              if (this.vertices.length > 0) {
                  // フラットシャドウ
                  ctx.save();
                  ctx.translate(3, 5);
                  ctx.beginPath();
                  ctx.moveTo(this.vertices[0].x, this.vertices[0].y);
                  for (let i = 1; i < this.vertices.length; i++) {
                      ctx.lineTo(this.vertices[i].x, this.vertices[i].y);
                  }
                  ctx.closePath();
                  ctx.fillStyle = "rgba(0, 0, 0, 0.3)";
                  ctx.fill();
                  ctx.restore();

                  // 本体多角形 (透過を少し減らして発色を最適化)
                  ctx.beginPath();
                  ctx.moveTo(this.vertices[0].x, this.vertices[0].y);
                  for (let i = 1; i < this.vertices.length; i++) {
                      ctx.lineTo(this.vertices[i].x, this.vertices[i].y);
                  }
                  ctx.closePath();
                  ctx.fillStyle = this.color + "e0";
                  ctx.fill();
              }

              // 外枠線
              ctx.lineWidth = 1.8;
              ctx.strokeStyle = "rgba(255, 255, 255, 0.45)";
              ctx.stroke();

              // テキスト情報
              ctx.fillStyle = "#ffffff";
              ctx.textAlign = "center";
              ctx.textBaseline = "middle";
              const fontBase = this.radius * 0.16;

              // タスクタイトル
              ctx.font = `bold ${Math.max(10, fontBase)}px sans-serif`;
              ctx.fillText(this.displayTitle, 0, -this.radius * 0.22);

              // 線
              ctx.strokeStyle = "rgba(255, 255, 255, 0.25)";
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(-this.sizeW * 0.35, -this.radius * 0.05);
              ctx.lineTo(this.sizeW * 0.35, -this.radius * 0.05);
              ctx.stroke();

              // タグ
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
              ctx.fillText(`🏷️: ${this.tag}`, 0, this.radius * 0.12);

              // 期限
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.75)";
              ctx.fillText(`📅: ${this.deadlineStr}`, 0, this.radius * 0.32);

              ctx.restore();
          }
      }

      const fragments = [];
      completedTasks.forEach(task => {
          fragments.push(new Fragment(task));
      });

      function loop() {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark' || !document.documentElement.getAttribute('data-theme');
          ctx.fillStyle = isDark ? "#070a13" : "#f1f5f9";
          ctx.fillRect(0, 0, width, height);

          fragments.forEach(f => {
              f.update();
              f.draw();
          });

          requestAnimationFrame(loop);
      }

      loop();
    </script>
  </body>
</html>
