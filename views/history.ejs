<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Task - 過去の歴史</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #0b0f19;
        --card-bg: #111827;
        --text: #f9fafb;
        --text-muted: #9ca3af;
        --border: #374151;
      }
      [data-theme="light"] {
        --bg: #f3f4f6;
        --card-bg: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
          background-color 0.3s,
          color 0.3s;
      }

      .btn {
        transition: all 0.2s ease;
        border-radius: 8px;
      }
      .btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
      }

      #historyCanvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: auto;
      }

      .overlay-ui {
        position: relative;
        z-index: 10;
        pointer-events: none;
      }
      .interactive-element {
        pointer-events: auto;
      }
    </style>
  </head>
  <body>
    <canvas id="historyCanvas"></canvas>

    <div class="overlay-ui flex flex-col h-full justify-between p-6">
      <header
        class="flex justify-between items-center bg-slate-900/80 backdrop-blur-md p-4 rounded-2xl border border-slate-700/50 interactive-element"
      >
        <div>
          <h1
            class="text-2xl font-black tracking-tight text-white flex items-center gap-2"
          >
            🌌 過去の歴史 (Shattered Universe)
          </h1>
          <p class="text-xs text-slate-400 mt-0.5">
            あなたが今までにこなしたタスクたちです。
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/"
            class="btn px-4 py-2 bg-slate-800 text-white font-bold text-sm border border-slate-700"
          >
            ↩ タスク盤面に戻る
          </a>
          <button
            id="themeToggle"
            class="btn p-2 bg-slate-800 text-lg border border-slate-700"
          >
            🌓
          </button>
        </div>
      </header>

      <footer
        class="bg-slate-900/80 backdrop-blur-md p-3 rounded-xl border border-slate-700/50 flex justify-between items-center interactive-element text-xs text-slate-400"
      >
        <span>🚀 観測中のかけら: <strong><%= tasks.length %></strong> 個</span>
        <span
          >💡
          マウスカーソルが近づいた破片だけが物理的に反応し、移動・回転します（超軽量設計）</span
        >
      </footer>
    </div>
    <script>
      const completedTasks = <%- JSON.stringify(tasks) %>;

      // テーマ切り替え
      if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      document.getElementById('themeToggle').addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          if (currentTheme === 'dark') {
              document.documentElement.removeAttribute('data-theme');
              localStorage.setItem('theme', 'light');
          } else {
              document.documentElement.setAttribute('data-theme', 'dark');
              localStorage.setItem('theme', 'dark');
          }
      });

      const canvas = document.getElementById('historyCanvas');
      const ctx = canvas.getContext('2d');
      let width = canvas.width = window.innerWidth;
      let height = canvas.height = window.innerHeight;

      window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
      });

      // マウス・ドラッグ管理用のオブジェクト
      const mouse = {
          x: -1000,
          y: -1000,
          isDown: false,
          vx: 0,
          vy: 0,
          lastX: 0,
          lastY: 0
      };

      // ドラッグ中の対象Fragment
      let draggedFragment = null;

      window.addEventListener('mousedown', (e) => {
          mouse.isDown = true;
          mouse.x = e.clientX;
          mouse.y = e.clientY;
          mouse.lastX = e.clientX;
          mouse.lastY = e.clientY;
          mouse.vx = 0;
          mouse.vy = 0;

          // クリックされたタスクを探す（重なりの順を考慮して後ろからループ）
          for (let i = fragments.length - 1; i >= 0; i--) {
              const f = fragments[i];
              const dx = mouse.x - f.x;
              const dy = mouse.y - f.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              // かけらの半径内をクリックしたか判定
              if (dist < f.radius) {
                  draggedFragment = f;
                  f.isDragging = true;
                  f.isSleeping = false;
                  break;
              }
          }
      });

      window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;

          if (mouse.isDown) {
              // マウス移動の瞬間速度を測定
              mouse.vx = e.clientX - mouse.lastX;
              mouse.vy = e.clientY - mouse.lastY;
          }
          mouse.lastX = e.clientX;
          mouse.lastY = e.clientY;
      });

      window.addEventListener('mouseup', () => {
          if (draggedFragment) {
              // マウスを離した時の速度をそのまま引き継ぐ（投げ飛ばす）
              draggedFragment.vx = mouse.vx * 0.8;
              draggedFragment.vy = mouse.vy * 0.8;
              // 投げられた強さに応じた回転スピンを設定
              const speed = Math.sqrt(mouse.vx * mouse.vx + mouse.vy * mouse.vy);
              draggedFragment.currentRotationSpeed = (mouse.vx > 0 ? 1 : -1) * Math.min(0.2, speed * 0.015);

              draggedFragment.isDragging = false;
              draggedFragment = null;
          }
          mouse.isDown = false;
      });

      // 🔥 日本時間タイムゾーンでの日付取得
      function formatToJST(dateString) {
          if (!dateString) return "-";
          const d = new Date(dateString);
          const formatter = new Intl.DateTimeFormat('ja-JP', {
              timeZone: 'Asia/Tokyo',
              year: 'numeric',
              month: '2-digit',
              day: '2-digit'
          });
          return formatter.format(d);
      }

      // 破片 (Fragment) クラス
      class Fragment {
          constructor(task) {
              this.title = task.title;
              this.tag = task.tag || "なし";
              this.deadline = new Date(task.deadline);
              this.deadlineStr = formatToJST(task.deadline);
              this.color = task.color || "#6366f1";
              this.importance = Number(task.importance) || 1;

              // 初期配置
              this.x = Math.random() * (width - 300) + 150;
              this.y = Math.random() * (height - 300) + 150;

              // 重要度の面積比例システム
              const baseRadius = 60;
              const scaleFactor = Math.sqrt(this.importance);
              this.radius = baseRadius * scaleFactor;

              // 「砕け散ったかけら」のデザイン頂点を事前生成
              this.points = [];
              const numPoints = 5 + Math.floor(Math.random() * 4); // 5〜8角形
              for (let i = 0; i < numPoints; i++) {
                  const angle = (i / numPoints) * Math.PI * 2;
                  const offsetRadius = this.radius * (0.8 + Math.random() * 0.4);
                  this.points.push({
                      x: Math.cos(angle) * offsetRadius,
                      y: Math.sin(angle) * offsetRadius
                  });
              }

              // 速度
              this.vx = 0;
              this.vy = 0;

              // 回転角度
              this.angle = Math.random() * Math.PI * 2;
              this.currentRotationSpeed = 0;

              // フラグ管理
              this.isDragging = false;
              this.isSleeping = true;
          }

          // ⚡ [ドラッグ&ドロップ対応物理エンジン]
          update() {
              if (this.isDragging) {
                  // ドラッグ中は、遅延なくマウスの動きに追従させる
                  this.x += (mouse.x - this.x) * 0.35;
                  this.y += (mouse.y - this.y) * 0.35;
                  this.vx = 0;
                  this.vy = 0;
                  this.currentRotationSpeed *= 0.9;
                  return;
              }

              if (this.isSleeping) return;

              // 🌀 摩擦抵抗 (空気抵抗)。5秒（約300フレーム）かけて、投げられた力が0に収束するように減衰率を設計
              // 0.985の減衰率をかけることで、5秒後に速度が十分に小さくなり、完全静止（スリープ）します
              this.vx *= 0.985;
              this.vy *= 0.985;
              this.currentRotationSpeed *= 0.98;

              this.x += this.vx;
              this.y += this.vy;
              this.angle += this.currentRotationSpeed;

              // 速度と回転が十分小さくなったら完全に静止（スリープ）
              if (Math.abs(this.vx) < 0.05 && Math.abs(this.vy) < 0.05 && Math.abs(this.currentRotationSpeed) < 0.001) {
                  this.vx = 0;
                  this.vy = 0;
                  this.currentRotationSpeed = 0;
                  this.isSleeping = true;
              }

              // 画面端の跳ね返り
              const boundR = this.radius;
              if (this.x - boundR < 0) {
                  this.x = boundR;
                  this.vx *= -0.7; // 跳ね返り時に少し威力をロスさせる
              } else if (this.x + boundR > width) {
                  this.x = width - boundR;
                  this.vx *= -0.7;
              }

              if (this.y - boundR < 0) {
                  this.y = boundR;
                  this.vy *= -0.7;
              } else if (this.y + boundR > height) {
                  this.y = height - boundR;
                  this.vy *= -0.7;
              }
          }

          draw() {
              // 画面外のものは描画スキップ
              const margin = this.radius * 1.5;
              if (this.x + margin < 0 || this.x - margin > width || this.y + margin < 0 || this.y - margin > height) {
                  return;
              }

              ctx.save();
              ctx.translate(this.x, this.y);
              ctx.rotate(this.angle);

              // ドラッグ中のハイライト用エフェクト
              if (this.isDragging) {
                  ctx.fillStyle = "rgba(255, 255, 255, 0.15)";
                  ctx.beginPath();
                  ctx.arc(0, 0, this.radius + 10, 0, Math.PI * 2);
                  ctx.fill();
              }

              // 1. 擬似シャドウ
              ctx.fillStyle = "rgba(0, 0, 0, 0.22)";
              ctx.beginPath();
              ctx.moveTo(this.points[0].x + 4, this.points[0].y + 4);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x + 4, this.points[i].y + 4);
              }
              ctx.closePath();
              ctx.fill();

              // 2. 「砕け散ったかけら」本体の描画
              ctx.beginPath();
              ctx.moveTo(this.points[0].x, this.points[0].y);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x, this.points[i].y);
              }
              ctx.closePath();
              ctx.fillStyle = this.color + (this.isDragging ? "f0" : "d4"); // ドラッグ中は少し鮮やかに
              ctx.fill();

              ctx.lineWidth = this.isDragging ? 2.5 : 1.8;
              ctx.strokeStyle = this.isDragging ? "rgba(255, 255, 255, 0.8)" : "rgba(255, 255, 255, 0.45)";
              ctx.stroke();

              // 3. テキスト描画
              ctx.fillStyle = "#ffffff";
              ctx.textAlign = "center";
              ctx.textBaseline = "middle";
              const fontBase = this.radius * 0.16;

              // タスク名
              ctx.font = `bold ${Math.max(10, fontBase)}px sans-serif`;
              let displayTitle = this.title;
              const maxW = this.radius * 1.5;
              if (ctx.measureText(displayTitle).width > maxW) {
                  while (ctx.measureText(displayTitle + "...").width > maxW && displayTitle.length > 0) {
                      displayTitle = displayTitle.slice(0, -1);
                  }
                  displayTitle += "...";
              }
              ctx.fillText(displayTitle, 0, -this.radius * 0.22);

              // 破片を縦断するシャープなクラック（亀裂線）
              ctx.strokeStyle = "rgba(255, 255, 255, 0.25)";
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(-this.radius * 0.6, -this.radius * 0.05);
              ctx.lineTo(this.radius * 0.6, -this.radius * 0.05);
              ctx.stroke();

              // タグ
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
              ctx.fillText(`🏷️: ${this.tag}`, 0, this.radius * 0.12);

              // 期限
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.75)";
              ctx.fillText(`📅: ${this.deadlineStr}`, 0, this.radius * 0.32);

              ctx.restore();
          }
      }

      const fragments = [];
      completedTasks.forEach(task => {
          fragments.push(new Fragment(task));
      });

      function loop() {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
                         !document.documentElement.getAttribute('data-theme');
          ctx.fillStyle = isDark ? "#070a13" : "#f1f5f9";
          ctx.fillRect(0, 0, width, height);

          fragments.forEach(f => {
              f.update();
              f.draw();
          });
          requestAnimationFrame(loop);
      }

      loop();
    </script>
  </body>
</html>
