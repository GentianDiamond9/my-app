<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Task - 過去の歴史</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #0b0f19;
        --card-bg: #111827;
        --text: #f9fafb;
        --text-muted: #9ca3af;
        --border: #374151;
      }
      [data-theme="light"] {
        --bg: #f3f4f6;
        --card-bg: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
          background-color 0.3s,
          color 0.3s;
      }

      .btn {
        transition: all 0.2s ease;
        border-radius: 8px;
      }
      .btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
      }

      #historyCanvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: auto;
      }

      .overlay-ui {
        position: relative;
        z-index: 10;
        pointer-events: none;
      }
      .interactive-element {
        pointer-events: auto;
      }
    </style>
  </head>
  <body>
    <canvas id="historyCanvas"></canvas>

    <div class="overlay-ui flex flex-col h-full justify-between p-6">
      <header
        class="flex justify-between items-center bg-slate-900/80 backdrop-blur-md p-4 rounded-2xl border border-slate-700/50 interactive-element"
      >
        <div>
          <h1
            class="text-2xl font-black tracking-tight text-white flex items-center gap-2"
          >
            🌌 過去の歴史 (Shattered Universe)
          </h1>
          <p class="text-xs text-slate-400 mt-0.5">
            あなたが今までにこなしたタスクたちです。
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/"
            class="btn px-4 py-2 bg-slate-800 text-white font-bold text-sm border border-slate-700"
          >
            ↩ タスク盤面に戻る
          </a>
          <button
            id="themeToggle"
            class="btn p-2 bg-slate-800 text-lg border border-slate-700"
          >
            🌓
          </button>
        </div>
      </header>

      <footer
        class="bg-slate-900/80 backdrop-blur-md p-3 rounded-xl border border-slate-700/50 flex justify-between items-center interactive-element text-xs text-slate-400"
      >
        <span>🚀 観測中のかけら: <strong><%= tasks.length %></strong> 個</span>
        <span
          >💡
          マウスカーソルが近づいた破片だけが物理的に反応し、移動・回転します（超軽量設計）</span
        >
      </footer>
    </div>
    <script>
       const completedTasks = <%- JSON.stringify(tasks) %>;

       // テーマ切り替え
       if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
       document.getElementById('themeToggle').addEventListener('click', () => {
           const currentTheme = document.documentElement.getAttribute('data-theme');
           if (currentTheme === 'dark') {
               document.documentElement.removeAttribute('data-theme');
               localStorage.setItem('theme', 'light');
           } else {
               document.documentElement.setAttribute('data-theme', 'dark');
               localStorage.setItem('theme', 'dark');
           }
       });

       const canvas = document.getElementById('historyCanvas');
       const ctx = canvas.getContext('2d');
       let width = canvas.width = window.innerWidth;
       let height = canvas.height = window.innerHeight;
       window.addEventListener('resize', () => {
           width = canvas.width = window.innerWidth;
           height = canvas.height = window.innerHeight;
       });

       // マウス位置 (初期位置は衝突しないよう画面外)
       const mouse = { x: -1000, y: -1000, radius: 200 };
       window.addEventListener('mousemove', (e) => {
           mouse.x = e.clientX;
           mouse.y = e.clientY;
       });
       window.addEventListener('mouseleave', () => {
           mouse.x = -1000;
           mouse.y = -1000;
       });

       // 🔥 【対策A】Intlを用いた日本時間タイムゾーンでの日付取得
       function formatToJST(dateString) {
           if (!dateString) return "-";
           const d = new Date(dateString);
           const formatter = new Intl.DateTimeFormat('ja-JP', {
               timeZone: 'Asia/Tokyo',
               year: 'numeric',
               month: '2-digit',
               day: '2-digit'
           });
           return formatter.format(d);
       }

      // 破片 (Fragment) クラス
      class Fragment {
          constructor(task) {
              this.title = task.title;
              this.tag = task.tag || "なし";
              this.deadline = new Date(task.deadline);
              this.deadlineStr = formatToJST(task.deadline); // より正確なJST日付表示
              this.color = task.color || "#6366f1";
              this.importance = Number(task.importance) || 1; // 1, 2, 3 のいずれか

              // 初期配置
              this.x = Math.random() * (width - 300) + 150;
              this.y = Math.random() * (height - 300) + 150;

              // 【重要度の面積比例システム】
              const baseRadius = 60;
              const scaleFactor = Math.sqrt(this.importance);
              this.radius = baseRadius * scaleFactor;

              // 📐 「砕け散ったかけら」のデザインを事前生成
              // 毎フレーム乱数を作ったり計算するのを防ぎ、配列にキャッシュします
              this.points = [];
              const numPoints = 5 + Math.floor(Math.random() * 4); // 5〜8角形
              for (let i = 0; i < numPoints; i++) {
                  const angle = (i / numPoints) * Math.PI * 2;
                  // 半径を少しランダムに伸縮させ、トゲトゲした「砕け散ったかけら」を表現
                  const offsetRadius = this.radius * (0.8 + Math.random() * 0.4);
                  this.points.push({
                      x: Math.cos(angle) * offsetRadius,
                      y: Math.sin(angle) * offsetRadius
                  });
              }

              // 速度
              const moveAngle = Math.random() * Math.PI * 2;
              const speed = 0.3 + Math.random() * 0.5;
              this.vx = Math.cos(moveAngle) * speed;
              this.vy = Math.sin(moveAngle) * speed;
              this.origVx = this.vx;
              this.origVy = this.vy;

              // 回転角度
              this.angle = Math.random() * Math.PI * 2;
              const now = new Date();
              const diffTimeMs = Math.max(1, now.getTime() - this.deadline.getTime());
              const daysOld = diffTimeMs / (1000 * 60 * 60 * 24);
              this.baseRotationSpeed = Math.max(0.001, 0.012 / (1 + (daysOld / 20)));
              if (Math.random() > 0.5) this.baseRotationSpeed *= -1;

              this.currentRotationSpeed = this.baseRotationSpeed;
          }

          // ⚡ [最適化] マウス反発の単純ベクトル計算
          update() {
              const dx = this.x - mouse.x;
              const dy = this.y - mouse.y;
              const distSq = dx * dx + dy * dy;
              const mouseRadiusSq = mouse.radius * mouse.radius;

              if (distSq < mouseRadiusSq) {
                  const dist = Math.sqrt(distSq) || 1;
                  const force = (mouse.radius - dist) / mouse.radius;

                  const dirX = dx / dist;
                  const dirY = dy / dist;

                  this.vx += dirX * force * 1.8;
                  this.vy += dirY * force * 1.8;

                  const spinAcceleration = (force * 0.03) / Math.sqrt(this.importance);
                  if (this.baseRotationSpeed > 0) {
                      this.currentRotationSpeed += spinAcceleration;
                  } else {
                      this.currentRotationSpeed -= spinAcceleration;
                  }
              } else {
                  this.vx += (this.origVx - this.vx) * 0.04;
                  this.vy += (this.origVy - this.vy) * 0.04;
                  this.currentRotationSpeed += (this.baseRotationSpeed - this.currentRotationSpeed) * 0.04;
              }

              const maxSpeed = 4.5;
              const currentSpeed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
              if (currentSpeed > maxSpeed) {
                  this.vx = (this.vx / currentSpeed) * maxSpeed;
                  this.vy = (this.vy / currentSpeed) * maxSpeed;
              }

              this.x += this.vx;
              this.y += this.vy;
              this.angle += this.currentRotationSpeed;

              // 画面端の跳ね返り
              const boundR = this.radius;
              if (this.x - boundR < 0) {
                  this.x = boundR;
                  this.vx *= -1;
                  this.origVx *= -1;
              } else if (this.x + boundR > width) {
                  this.x = width - boundR;
                  this.vx *= -1;
                  this.origVx *= -1;
              }

              if (this.y - boundR < 0) {
                  this.y = boundR;
                  this.vy *= -1;
                  this.origVy *= -1;
              } else if (this.y + boundR > height) {
                  this.y = height - boundR;
                  this.vy *= -1;
                  this.origVy *= -1;
              }
          }

          draw() {
              // ⚡ [超軽量化] 画面の外（見えない領域）にいるかけらは描画処理を完全にスキップ
              const margin = this.radius * 1.5;
              if (this.x + margin < 0 || this.x - margin > width || this.y + margin < 0 || this.y - margin > height) {
                  return;
              }

              ctx.save();
              ctx.translate(this.x, this.y);
              ctx.rotate(this.angle);

              // 1. 擬似シャドウ（事前計算済みの頂点配列を使用）
              ctx.fillStyle = "rgba(0, 0, 0, 0.25)";
              ctx.beginPath();
              ctx.moveTo(this.points[0].x + 4, this.points[0].y + 4);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x + 4, this.points[i].y + 4);
              }
              ctx.closePath();
              ctx.fill();

              // 2. 砕けたかけら本体の描画（事前計算済みの頂点配列を再利用）
              ctx.beginPath();
              ctx.moveTo(this.points[0].x, this.points[0].y);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x, this.points[i].y);
              }
              ctx.closePath();
              ctx.fillStyle = this.color + "d4"; // 透明度を含めたカラー
              ctx.fill();

              ctx.lineWidth = 1.8;
              ctx.strokeStyle = "rgba(255, 255, 255, 0.45)";
              ctx.stroke();

              // 3. テキストの描画
              ctx.fillStyle = "#ffffff";
              ctx.textAlign = "center";
              ctx.textBaseline = "middle";
              const fontBase = this.radius * 0.16;

              // タスク名
              ctx.font = `bold ${Math.max(10, fontBase)}px sans-serif`;
              let displayTitle = this.title;
              const maxW = this.radius * 1.5;
              if (ctx.measureText(displayTitle).width > maxW) {
                  while (ctx.measureText(displayTitle + "...").width > maxW && displayTitle.length > 0) {
                      displayTitle = displayTitle.slice(0, -1);
                  }
                  displayTitle += "...";
              }
              ctx.fillText(displayTitle, 0, -this.radius * 0.22);

              // 破片を縦断するシャープなクラック（亀裂線）
              ctx.strokeStyle = "rgba(255, 255, 255, 0.25)";
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(-this.radius * 0.6, -this.radius * 0.05);
              ctx.lineTo(this.radius * 0.6, -this.radius * 0.05);
              ctx.stroke();

              // タグ
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
              ctx.fillText(`🏷️: ${this.tag}`, 0, this.radius * 0.12);

              // 期限
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.75)";
              ctx.fillText(`📅: ${this.deadlineStr}`, 0, this.radius * 0.32);

              ctx.restore();
          }
      }

       const fragments = [];
       completedTasks.forEach(task => {
           fragments.push(new Fragment(task));
       });

       function loop() {
           const isDark = document.documentElement.getAttribute('data-theme') === 'dark' || !document.documentElement.getAttribute('data-theme');
           ctx.fillStyle = isDark ? "#070a13" : "#f1f5f9";
           ctx.fillRect(0, 0, width, height);

           fragments.forEach(f => {
               f.update();
               f.draw();
           });

           requestAnimationFrame(loop);
       }

       loop();
    </script>
  </body>
</html>
