<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Task - 過去の歴史</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #0b0f19;
        --card-bg: #111827;
        --text: #f9fafb;
        --text-muted: #9ca3af;
        --border: #374151;
      }
      [data-theme="light"] {
        --bg: #f3f4f6;
        --card-bg: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden; /* Canvasと連動して画面いっぱいに */
        height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
          background-color 0.3s,
          color 0.3s;
      }

      .btn {
        transition: all 0.2s ease;
        border-radius: 8px;
      }
      .btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
      }

      /* 歴史観測の巨大キャンバス */
      #historyCanvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: auto;
      }

      /* オーバーレイUIをキャンバスの手前に配置 */
      .overlay-ui {
        position: relative;
        z-index: 10;
        pointer-events: none; /* UIの透過 */
      }
      .interactive-element {
        pointer-events: auto; /* UI部品のみクリック可能 */
      }
    </style>
  </head>
  <body>
    <!-- 🌌 キャンバス本体 -->
    <canvas id="historyCanvas"></canvas>

    <!-- 🛠️ インタラクティブオーバーレイUI -->
    <div class="overlay-ui flex flex-col h-full justify-between p-6">
      <!-- 上部ヘッダー -->
      <header
        class="flex justify-between items-center bg-slate-900/80 backdrop-blur-md p-4 rounded-2xl border border-slate-700/50 interactive-element"
      >
        <div>
          <h1
            class="text-2xl font-black tracking-tight text-white flex items-center gap-2"
          >
            🌌 過去の歴史 (Shattered Universe)
          </h1>
          <p class="text-xs text-slate-400 mt-0.5">
            砕け散った過去のタスクが、等速で空間を漂っています。マウスを近づけると反発します。
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/"
            class="btn px-4 py-2 bg-slate-800 text-white font-bold text-sm border border-slate-700"
          >
            ↩ タスク盤面に戻る
          </a>
          <button
            id="themeToggle"
            class="btn p-2 bg-slate-800 text-lg border border-slate-700"
          >
            🌓
          </button>
        </div>
      </header>

      <!-- 下部ステータスバー -->
      <footer
        class="bg-slate-900/80 backdrop-blur-md p-3 rounded-xl border border-slate-700/50 flex justify-between items-center interactive-element text-xs text-slate-400"
      >
        <span
          >🚀 表示中:
          <strong><%= tasks.length %></strong> 個の完了済みタスク</span
        >
        <span
          >💡 破片数 = 優先度 × 2個（重なりゼロ、相互干渉なしの物理演算）</span
        >
      </footer>
    </div>

    <script>
      // サーバーから渡された完了済みタスク一覧
      const completedTasks = <%- JSON.stringify(tasks) %>;

      // テーマ切り替え
      if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      document.getElementById('themeToggle').addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          if (currentTheme === 'dark') {
              document.documentElement.removeAttribute('data-theme');
              localStorage.setItem('theme', 'light');
          } else {
              document.documentElement.setAttribute('data-theme', 'dark');
              localStorage.setItem('theme', 'dark');
          }
      });

      // --- 物理2Dパーティクル・シミュレーションエンジニアリング ---
      const canvas = document.getElementById('historyCanvas');
      const ctx = canvas.getContext('2d');

      let width = canvas.width = window.innerWidth;
      let height = canvas.height = window.innerHeight;

      window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
      });

      // マウス位置
      const mouse = { x: -1000, y: -1000, radius: 150 };
      window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;
      });
      window.addEventListener('mouseleave', () => {
          mouse.x = -1000;
          mouse.y = -1000;
      });

      // 破片 (Fragment) クラス
      class Fragment {
          constructor(task, index, totalFragments) {
              this.title = task.title;
              this.tag = task.tag || "なし";
              this.deadline = new Date(task.deadline).toLocaleDateString();
              this.color = task.color || "#6366f1";
              this.importance = task.importance;

              // 初期配置は画面全体にランダム
              this.x = Math.random() * width;
              this.y = Math.random() * height;

              // 優先度が高いほどサイズを大きく調整
              this.sizeW = 140 + (this.importance * 15);
              this.sizeH = 75 + (this.importance * 10);

              // 等速運動ベクトル
              const angle = Math.random() * Math.PI * 2;
              const speed = 0.5 + Math.random() * 0.8; // 穏やかな等速直線運動
              this.vx = Math.cos(angle) * speed;
              this.vy = Math.sin(angle) * speed;

              // マウス反発後の収束速度係数
              this.origVx = this.vx;
              this.origVy = this.vy;
          }

          update() {
              // マウス反発ロジック
              const dx = this.x + this.sizeW / 2 - mouse.x;
              const dy = this.y + this.sizeH / 2 - mouse.y;
              const dist = Math.sqrt(dx * dx + dy * dy);

              if (dist < mouse.radius) {
                  const force = (mouse.radius - dist) / mouse.radius; // 近いほど強い力
                  const angle = Math.atan2(dy, dx);
                  // 反発加速度を付与
                  this.vx += Math.cos(angle) * force * 1.5;
                  this.vy += Math.sin(angle) * force * 1.5;
              } else {
                  // 徐々に元の等速運動に戻す (減衰収束)
                  this.vx += (this.origVx - this.vx) * 0.05;
                  this.vy += (this.origVy - this.vy) * 0.05;
              }

              // 速度制限 (暴走防止)
              const maxSpeed = 6;
              const currentSpeed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
              if (currentSpeed > maxSpeed) {
                  this.vx = (this.vx / currentSpeed) * maxSpeed;
                  this.vy = (this.vy / currentSpeed) * maxSpeed;
              }

              // 位置更新
              this.x += this.vx;
              this.y += this.vy;

              // 画面端バウンド処理
              if (this.x < 0) {
                  this.x = 0;
                  this.vx *= -1;
                  this.origVx *= -1;
              } else if (this.x + this.sizeW > width) {
                  this.x = width - this.sizeW;
                  this.vx *= -1;
                  this.origVx *= -1;
              }

              if (this.y < 0) {
                  this.y = 0;
                  this.vy *= -1;
                  this.origVy *= -1;
              } else if (this.y + this.sizeH > height) {
                  this.y = height - this.sizeH;
                  this.vy *= -1;
                  this.origVy *= -1;
              }
          }

          draw() {
              ctx.save();

              // カード風シャドウと角丸矩形描画
              ctx.shadowColor = 'rgba(0, 0, 0, 0.4)';
              ctx.shadowBlur = 10;
              ctx.shadowOffsetX = 3;
              ctx.shadowOffsetY = 5;

              // 半透明の背景にして奥行き感を持たせる
              ctx.fillStyle = this.color + "cc"; // cc = 80% opacity

              // 角丸四角形
              const radius = 8;
              ctx.beginPath();
              ctx.moveTo(this.x + radius, this.y);
              ctx.lineTo(this.x + this.sizeW - radius, this.y);
              ctx.quadraticCurveTo(this.x + this.sizeW, this.y, this.x + this.sizeW, this.y + radius);
              ctx.lineTo(this.x + this.sizeW, this.y + this.sizeH - radius);
              ctx.quadraticCurveTo(this.x + this.sizeW, this.y + this.sizeH, this.x + this.sizeW - radius, this.y + this.sizeH);
              ctx.lineTo(this.x + radius, this.y + this.sizeH);
              ctx.quadraticCurveTo(this.x, this.y + this.sizeH, this.x, this.y + this.sizeH - radius);
              ctx.lineTo(this.x, this.y + radius);
              ctx.quadraticCurveTo(this.x, this.y, this.x + radius, this.y);
              ctx.closePath();
              ctx.fill();

              // 枠線
              ctx.lineWidth = 1;
              ctx.strokeStyle = "rgba(255, 255, 255, 0.25)";
              ctx.stroke();

              // シャドウリセット
              ctx.shadowBlur = 0;
              ctx.shadowOffsetX = 0;
              ctx.shadowOffsetY = 0;

              // テキスト描画 (色、名前、タグ、期限を表示)
              ctx.fillStyle = "#ffffff";

              // 1. 名前 (Title)
              ctx.font = "bold 11px sans-serif";
              const maxTextWidth = this.sizeW - 16;
              let displayTitle = this.title;
              if (ctx.measureText(displayTitle).width > maxTextWidth) {
                  // 簡易的なトリム
                  while (ctx.measureText(displayTitle + "...").width > maxTextWidth && displayTitle.length > 0) {
                      displayTitle = displayTitle.slice(0, -1);
                  }
                  displayTitle += "...";
              }
              ctx.fillText(displayTitle, this.x + 10, this.y + 20);

              // 分割線
              ctx.strokeStyle = "rgba(255, 255, 255, 0.15)";
              ctx.beginPath();
              ctx.moveTo(this.x + 8, this.y + 28);
              ctx.lineTo(this.x + this.sizeW - 8, this.y + 28);
              ctx.stroke();

              // 2. タグ (Tag)
              ctx.font = "9px sans-serif";
              ctx.fillText(`🏷️: ${this.tag}`, this.x + 10, this.y + 42);

              // 3. 期限 (Deadline)
              ctx.fillText(`📅: ${this.deadline}`, this.x + 10, this.y + 54);

              // 4. カラーコード/重要度
              ctx.fillStyle = "rgba(255, 255, 255, 0.7)";
              ctx.font = "8px monospace";
              ctx.fillText(`Color: ${this.color.toUpperCase()}`, this.x + 10, this.y + 66);

              ctx.restore();
          }
      }

      // 破片配列の初期構築
      const fragments = [];
      completedTasks.forEach(task => {
          // 各タスクにつき 優先度 (importance) × 2 個の破片を生成
          const count = task.importance * 2;
          for (let i = 0; i < count; i++) {
              fragments.push(new Fragment(task, i, count));
          }
      });

      // アニメーションループ
      function loop() {
          // 背景クリア (テーマに合わせてクリアカラーを変更)
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark' || !document.documentElement.getAttribute('data-theme');
          ctx.fillStyle = isDark ? "#0b0f19" : "#f3f4f6";
          ctx.fillRect(0, 0, width, height);

          // 破片の描画・更新
          fragments.forEach(f => {
              f.update();
              f.draw();
          });

          requestAnimationFrame(loop);
      }

      loop();
    </script>
  </body>
</html>
