<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visual Task - 過去の歴史</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --bg: #0b0f19;
        --card-bg: #111827;
        --text: #f9fafb;
        --text-muted: #9ca3af;
        --border: #374151;
      }
      [data-theme="light"] {
        --bg: #f3f4f6;
        --card-bg: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
          background-color 0.3s,
          color 0.3s;
      }

      header {
        background-color: var(--card-bg);
        border-bottom: 1px solid var(--border);
        z-index: 10;
        transition:
          background-color 0.3s,
          border-color 0.3s;
      }

      canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: block;
        z-index: 1;
      }

      .ui-container {
        position: relative;
        z-index: 10;
        pointer-events: none;
      }

      .interactive {
        pointer-events: auto;
      }
    </style>
  </head>
  <body>
    <header class="py-4 px-6 flex justify-between items-center shadow-md">
      <div class="flex items-center space-x-4">
        <a
          href="/"
          class="text-xl font-bold tracking-wider text-indigo-500 hover:text-indigo-400 transition"
          >← BACK TO BOARD</a
        >
        <span class="text-sm text-[var(--text-muted)] hidden md:inline">|</span>
        <h1 class="text-lg font-medium hidden md:inline">過去の歴史</h1>
      </div>
      <div class="flex items-center space-x-3">
        <button
          id="themeToggle"
          class="p-2 rounded-full bg-slate-800 dark:bg-slate-200 text-yellow-400 dark:text-indigo-900 hover:scale-110 transition"
        >
          🌓
        </button>
      </div>
    </header>

    <div class="ui-container p-6 absolute top-16 left-0">
      <div
        class="bg-[var(--card-bg)] bg-opacity-80 backdrop-blur border border-[var(--border)] p-4 rounded-xl shadow-lg max-w-sm"
      >
        <h2 class="text-md font-bold mb-1">
          あなたが今までにこなしたタスクたちです。
        </h2>
        <p class="text-xs text-[var(--text-muted)] leading-relaxed">
          タスクをクリック（タップ）してドラッグし、スワイプするように投げ飛ばすことができます。投げ飛ばされたかけらは壁を跳ね返り、5秒でぴったり静止します。
        </p>
      </div>
    </div>

    <canvas id="historyCanvas"></canvas>

    <script>
      const completedTasks = <%- JSON.stringify(tasks) %>;

      // テーマ切り替え
      if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      document.getElementById('themeToggle').addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          if (currentTheme === 'dark') {
              document.documentElement.removeAttribute('data-theme');
              localStorage.setItem('theme', 'light');
          } else {
              document.documentElement.setAttribute('data-theme', 'dark');
              localStorage.setItem('theme', 'dark');
          }
      });

      const canvas = document.getElementById('historyCanvas');
      const ctx = canvas.getContext('2d');
      let width = canvas.width = window.innerWidth;
      let height = canvas.height = window.innerHeight;

      window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
      });

      // マウス・ドラッグ管理用のオブジェクト
      const mouse = {
          x: -1000,
          y: -1000,
          isDown: false,
          vx: 0,
          vy: 0,
          lastX: 0,
          lastY: 0
      };

      // ドラッグ中の対象Fragment
      let draggedFragment = null;

      window.addEventListener('mousedown', (e) => {
          mouse.isDown = true;
          mouse.x = e.clientX;
          mouse.y = e.clientY;
          mouse.lastX = e.clientX;
          mouse.lastY = e.clientY;
          mouse.vx = 0;
          mouse.vy = 0;

          // クリックされたタスクを探す（重なりの順を考慮して後ろからループ）
          for (let i = fragments.length - 1; i >= 0; i--) {
              const f = fragments[i];
              const dx = mouse.x - f.x;
              const dy = mouse.y - f.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              // かけらの半径内をクリックしたか判定
              if (dist < f.radius) {
                  draggedFragment = f;
                  f.isDragging = true;
                  f.isSleeping = false;
                  break;
              }
          }
      });

      window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;

          if (mouse.isDown) {
              // マウス移動の瞬間速度を測定
              mouse.vx = e.clientX - mouse.lastX;
              mouse.vy = e.clientY - mouse.lastY;
          }
          mouse.lastX = e.clientX;
          mouse.lastY = e.clientY;
      });

      window.addEventListener('mouseup', () => {
          if (draggedFragment) {
              // 投げ飛ばされた瞬間の初期速度を設定
              draggedFragment.vx = mouse.vx * 0.8;
              draggedFragment.vy = mouse.vy * 0.8;

              // 初期速度の「スカラー（速さ）」を厳密にキャッシュ
              draggedFragment.initialSpeed = Math.sqrt(draggedFragment.vx * draggedFragment.vx + draggedFragment.vy * draggedFragment.vy);

              // スピン初期速度
              draggedFragment.initSpin = (mouse.vx > 0 ? 1 : -1) * Math.min(0.2, draggedFragment.initialSpeed * 0.015);
              draggedFragment.currentRotationSpeed = draggedFragment.initSpin;

              // 投げ飛ばした実時間（ミリ秒）を記録
              draggedFragment.throwStartTime = Date.now();

              draggedFragment.isDragging = false;
              draggedFragment = null;
          }
          mouse.isDown = false;
      });

      // 日本時間タイムゾーンでの日付取得
      function formatToJST(dateString) {
          if (!dateString) return "-";
          const d = new Date(dateString);
          const formatter = new Intl.DateTimeFormat('ja-JP', {
              timeZone: 'Asia/Tokyo',
              year: 'numeric',
              month: '2-digit',
              day: '2-digit'
          });
          return formatter.format(d);
      }

      // 破片 (Fragment) クラス
      class Fragment {
          constructor(task) {
              this.title = task.title;
              this.tag = task.tag || "なし";
              this.deadline = new Date(task.deadline);
              this.deadlineStr = formatToJST(task.deadline);
              this.color = task.color || "#6366f1";
              this.importance = Number(task.importance) || 1;

              // 初期配置
              this.x = Math.random() * (width - 300) + 150;
              this.y = Math.random() * (height - 300) + 150;

              // 重要度の面積比例システム
              const baseRadius = 60;
              const scaleFactor = Math.sqrt(this.importance);
              this.radius = baseRadius * scaleFactor;

              // 「砕け散ったかけら」のデザイン頂点を事前生成
              this.points = [];
              const numPoints = 5 + Math.floor(Math.random() * 4); // 5〜8角形
              for (let i = 0; i < numPoints; i++) {
                  const angle = (i / numPoints) * Math.PI * 2;
                  const offsetRadius = this.radius * (0.8 + Math.random() * 0.4);
                  this.points.push({
                      x: Math.cos(angle) * offsetRadius,
                      y: Math.sin(angle) * offsetRadius
                  });
              }

              // 速度
              this.vx = 0;
              this.vy = 0;
              this.initialSpeed = 0;

              // 回転角度
              this.angle = Math.random() * Math.PI * 2;
              this.currentRotationSpeed = 0;
              this.initSpin = 0;

              // 投げ飛ばされた時間を記録するプロパティ（0なら静止中）
              this.throwStartTime = 0;

              // フラグ管理
              this.isDragging = false;
              this.isSleeping = true;
          }

          // ⚡ [実時間ベース等速直線減衰（バグ修正版）]
          update() {
              if (this.isDragging) {
                  this.x += (mouse.x - this.x) * 0.35;
                  this.y += (mouse.y - this.y) * 0.35;
                  this.vx = 0;
                  this.vy = 0;
                  this.currentRotationSpeed = 0;
                  this.throwStartTime = 0;
                  return;
              }

              if (this.isSleeping) return;

              // 実時間による等速直線減衰
              if (this.throwStartTime > 0) {
                  const elapsed = Date.now() - this.throwStartTime; // 投げ飛ばしてからの実経過時間 (ミリ秒)
                  const duration = 5000; // 💡 ぴったり5秒 (5000ミリ秒)

                  if (elapsed >= duration) {
                      // 5秒経過した瞬間に、物理挙動を「完全即座静止」させスリープにする
                      this.vx = 0;
                      this.vy = 0;
                      this.currentRotationSpeed = 0;
                      this.throwStartTime = 0;
                      this.isSleeping = true;
                      return;
                  }

                  // 残り時間に応じた比率 (1.0 から 5秒かけて直線的に 0.0 まで減少)
                  const ratio = 1 - (elapsed / duration);

                  // 現在の進行方向のベクトルを維持したまま、ターゲットの速さに厳密にスケールダウンさせる
                  const currentSpeed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
                  const targetSpeed = this.initialSpeed * ratio;

                  if (currentSpeed > 0.05 && targetSpeed > 0.05) {
                      // 壁跳ね返り後の方向を破壊せず、かつ目標の減衰速度に修正
                      const scale = targetSpeed / currentSpeed;
                      this.vx *= scale;
                      this.vy *= scale;
                  } else {
                      this.vx = 0;
                      this.vy = 0;
                  }

                  // スピン速度も直線的に減衰
                  this.currentRotationSpeed = this.initSpin * ratio;
              }

              // 座標と回転の適用
              this.x += this.vx;
              this.y += this.vy;
              this.angle += this.currentRotationSpeed;

              // 画面端の跳ね返り (摩擦ロスなどを入れず、進む方向だけをきれいに反転)
              const boundR = this.radius;
              if (this.x - boundR < 0) {
                  this.x = boundR;
                  this.vx *= -1;
              } else if (this.x + boundR > width) {
                  this.x = width - boundR;
                  this.vx *= -1;
              }

              if (this.y - boundR < 0) {
                  this.y = boundR;
                  this.vy *= -1;
              } else if (this.y + boundR > height) {
                  this.y = height - boundR;
                  this.vy *= -1;
              }
          }

          draw() {
              // 画面外のものは描画スキップ
              const margin = this.radius * 1.5;
              if (this.x + margin < 0 || this.x - margin > width || this.y + margin < 0 || this.y - margin > height) {
                  return;
              }

              ctx.save();
              ctx.translate(this.x, this.y);
              ctx.rotate(this.angle);

              // ドラッグ中のハイライト用エフェクト
              if (this.isDragging) {
                  ctx.fillStyle = "rgba(255, 255, 255, 0.15)";
                  ctx.beginPath();
                  ctx.arc(0, 0, this.radius + 10, 0, Math.PI * 2);
                  ctx.fill();
              }

              // 1. 擬似シャドウ
              ctx.fillStyle = "rgba(0, 0, 0, 0.22)";
              ctx.beginPath();
              ctx.moveTo(this.points[0].x + 4, this.points[0].y + 4);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x + 4, this.points[i].y + 4);
              }
              ctx.closePath();
              ctx.fill();

              // 2. 「砕け散ったかけら」本体の描画
              ctx.beginPath();
              ctx.moveTo(this.points[0].x, this.points[0].y);
              for (let i = 1; i < this.points.length; i++) {
                  ctx.lineTo(this.points[i].x, this.points[i].y);
              }
              ctx.closePath();
              ctx.fillStyle = this.color + (this.isDragging ? "f0" : "d4");
              ctx.fill();

              ctx.lineWidth = this.isDragging ? 2.5 : 1.8;
              ctx.strokeStyle = this.isDragging ? "rgba(255, 255, 255, 0.8)" : "rgba(255, 255, 255, 0.45)";
              ctx.stroke();

              // 3. テキスト描画
              ctx.fillStyle = "#ffffff";
              ctx.textAlign = "center";
              ctx.textBaseline = "middle";
              const fontBase = this.radius * 0.16;

              // タスク名
              ctx.font = `bold ${Math.max(10, fontBase)}px sans-serif`;
              let displayTitle = this.title;
              const maxW = this.radius * 1.5;
              if (ctx.measureText(displayTitle).width > maxW) {
                  while (ctx.measureText(displayTitle + "...").width > maxW && displayTitle.length > 0) {
                      displayTitle = displayTitle.slice(0, -1);
                  }
                  displayTitle += "...";
              }
              ctx.fillText(displayTitle, 0, -this.radius * 0.22);

              // クラック (亀裂線)
              ctx.strokeStyle = "rgba(255, 255, 255, 0.25)";
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(-this.radius * 0.6, -this.radius * 0.05);
              ctx.lineTo(this.radius * 0.6, -this.radius * 0.05);
              ctx.stroke();

              // タグ
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
              ctx.fillText(`🏷️: ${this.tag}`, 0, this.radius * 0.12);

              // 期限
              ctx.font = `${Math.max(8, fontBase * 0.8)}px sans-serif`;
              ctx.fillStyle = "rgba(255, 255, 255, 0.75)";
              ctx.fillText(`📅: ${this.deadlineStr}`, 0, this.radius * 0.32);

              ctx.restore();
          }
      }

      const fragments = [];
      completedTasks.forEach(task => {
          fragments.push(new Fragment(task));
      });

      function loop() {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
                         !document.documentElement.getAttribute('data-theme');
          ctx.fillStyle = isDark ? "#070a13" : "#f1f5f9";
          ctx.fillRect(0, 0, width, height);

          fragments.forEach(f => {
              f.update();
              f.draw();
          });
          requestAnimationFrame(loop);
      }

      loop();
    </script>
  </body>
</html>
