<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>タスク管理 & 高機能ツリーマップビュー</title>
    <style>
        /* --- スタイルテーマ定義 --- */
        :root {
            --bg-color: #f8f9fa;
            --card-bg: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #dee2e6;
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --default-node-color: #64748b; /* 指定なし時の灰色 */
        }

        [data-theme="dark"] {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --default-node-color: #475569;
        }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px;
            transition: background-color 0.3s, color 0.3s;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .theme-toggle-btn {
            background-color: var(--card-bg);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }
        @media(min-width: 768px) {
            .main-container { grid-template-columns: 1fr 1.2fr; }
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        /* --- タスクリスト --- */
        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
        }
        .task-item:last-child { border-bottom: none; }
        .task-info { display: flex; flex-direction: column; gap: 4px; }
        .completed { text-decoration: line-through; color: var(--text-muted); opacity: 0.6; }
        .deadline-text { font-size: 0.85rem; color: var(--text-muted); }

        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
        }
        .btn-success { background-color: var(--success-color); color: white; }
        .btn-warning { background-color: var(--warning-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; margin-left: 6px; }
        
        .badge {
            display: inline-block;
            padding: 2px 6px;
            font-size: 0.75rem;
            border-radius: 4px;
            font-weight: bold;
            margin-right: 6px;
            color: white;
        }
        .badge-3 { background-color: #ef4444; }
        .badge-2 { background-color: #f59e0b; }
        .badge-1 { background-color: #3b82f6; }

        /* タグ用のカスタムバッジ */
        .tag-badge {
            background-color: var(--border-color);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 1px 6px;
            font-size: 0.75rem;
            border-radius: 12px;
            margin-left: 6px;
        }

        /* カラープレビューサークル */
        .color-dot {
            display: inline-block;
            width: 100%;
            height: 4px;
            border-radius: 2px;
            margin-top: 4px;
        }

        /* --- ツリーマップ & オーバーレイ詳細 --- */
        .treemap-wrapper {
            width: 100%;
            height: 500px;
            background-color: var(--bg-color);
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }

        .treemap-node {
            position: absolute;
            box-sizing: border-box;
            border: 1px solid var(--card-bg);
            padding: 6px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            overflow: hidden;
            transition: all 0.2s ease-in-out;
            color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.6);
            cursor: pointer;
        }
        .treemap-node:hover {
            transform: scale(0.99);
            filter: brightness(1.1);
            z-index: 10;
        }

        .node-title { font-weight: bold; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .node-size { opacity: 0.9; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .detail-overlay {
            position: absolute;
            bottom: 12px;
            left: 12px;
            right: 12px;
            background-color: rgba(15, 23, 42, 0.95);
            color: #ffffff;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #334155;
            font-size: 0.9rem;
            display: none;
            z-index: 100;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);
            pointer-events: none;
        }

        form { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
        .form-group { display: flex; flex-direction: column; gap: 4px; }
        .form-row { display: grid; grid-template-columns: 2fr 1fr; gap: 12px; }
        input, select {
            padding: 8px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            background-color: var(--card-bg);
            color: var(--text-color);
        }
        input[type="color"] { padding: 2px; height: 38px; width: 100%; cursor: pointer; }
        .btn-primary { background-color: var(--primary-color); color: white; padding: 10px; font-weight: bold; border: none; border-radius: 6px;}
    </style>
</head>
<body>

    <header>
        <h1>TreeMap Tasks Premium</h1>
        <button class="theme-toggle-btn" id="themeToggle">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <h2>マイ・タスク</h2>
                <div id="taskList">
                    <% if (tasks.length === 0) { %>
                        <p style="color: var(--text-muted);">タスクはまだありません。</p>
                    <% } %>
                    <% 
                        // 重複しない既存のタグ一覧を抽出して、datalist用の配列を作る
                        const existingTags = [...new Set(tasks.map(t => t.tag).filter(Boolean))];
                        tasks.forEach(task => { 
                            const labels = {3: '高', 2: '中', 1: '低'};
                    %>
                        <div class="task-item" id="task-<%= task.id %>">
                            <div class="task-info">
                                <span class="<%= task.is_completed ? 'completed' : '' %>" id="title-<%= task.id %>">
                                    <span class="badge badge-<%= task.importance %>">重要度: <%= labels[task.importance] %></span>
                                    <strong><%= task.title %></strong>
                                    <% if (task.tag) { %>
                                        <span class="tag-badge">🏷️ <%= task.tag %></span>
                                    <% } %>
                                </span>
                                <span class="deadline-text" id="deadline-<%= task.id %>">
                                    ⏳ 期限: <%= new Date(task.deadline).toLocaleDateString() %>
                                </span>
                                <% if (task.color) { %>
                                    <span class="color-dot" style="background-color: <%= task.color %>;"></span>
                                <% } %>
                            </div>
                            <div id="actions-<%= task.id %>">
                                <% if (task.is_completed) { %>
                                    <button class="btn btn-warning toggle-btn" data-id="<%= task.id %>" data-status="false">戻す</button>
                                <% } else { %>
                                    <button class="btn btn-success toggle-btn" data-id="<%= task.id %>" data-status="true">完了</button>
                                <% } %>
                                <button class="btn btn-danger delete-btn" data-id="<%= task.id %>">削除</button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

                   <!-- 統計カードの追加 -->
        <div class="card" style="margin-top: 24px;">
            <h2>期限内達成率</h2>
            <div style="display: flex; justify-content: space-around; text-align: center; margin-top: 15px;">
                <div>
                    <div style="font-size: 0.85rem; color: var(--text-muted);">過去1週間</div>
                    <div style="font-size: 1.8rem; font-weight: bold; color: var(--success-color);"><%= stats.weekRate %>%</div>
                </div>
                <div>
                    <div style="font-size: 0.85rem; color: var(--text-muted);">過去1か月</div>
                    <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-color);"><%= stats.monthRate %>%</div>
                </div>
            </div>
        </div>
    </div> <!-- .main-container の閉じタグ -->

    <script>
    const tasks = <%- JSON.stringify(tasks) %>;
    const treemapContainer = document.getElementById('treemap');

    // 1. ツリーマップ描画
    function renderTreemap() {
        treemapContainer.innerHTML = '';
        const pendingTasks = tasks.filter(t => !t.is_completed);
        if (pendingTasks.length === 0) {
            treemapContainer.innerHTML = '<p style="padding:20px; color:var(--text-muted);">未完了のタスクはありません。</p>';
            return;
        }

        const now = new Date();
        const nodes = pendingTasks.map(task => {
            const deadline = new Date(task.deadline);
            const overdueMs = now - deadline;
            const overdueDays = overdueMs / (1000 * 60 * 60 * 24);
            // 期限超過で面積を大きくする（1日ごとに+1倍。期限内は1倍）
            const multiplier = 1 + Math.max(0, overdueDays);
            const value = task.importance * multiplier;
            return { ...task, value };
        });

        const totalValue = nodes.reduce((sum, n) => sum + n.value, 0);
        let currentX = 0;
        nodes.forEach(node => {
            const nodeWidth = (node.value / totalValue) * treemapContainer.offsetWidth;
            const div = document.createElement('div');
            div.className = 'treemap-node';
            div.style.width = `${nodeWidth}px`;
            div.style.height = `100%`;
            div.style.left = `${currentX}px`;
            div.style.backgroundColor = node.color || 'var(--default-node-color)';
            div.innerHTML = `<div class="node-title">${node.title}</div><div class="node-size">${Math.round(node.value * 10) / 10} pts</div>`;
            treemapContainer.appendChild(div);
            currentX += nodeWidth;
        });
    }

    // 2. ボタンイベント（再読み込みを確実にする）
    document.addEventListener('click', async (e) => {
        const id = e.target.dataset.id;
        
        // 完了・戻すボタン
        if (e.target.classList.contains('toggle-btn')) {
            const status = e.target.dataset.status;
            await fetch(`/tasks/${id}`, {
                method: 'PATCH',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: `is_completed=${status}`
            }).finally(() => location.href = "/"); // 確実にトップへ戻して再読込
        }

        // 削除ボタン
        if (e.target.classList.contains('delete-btn')) {
            if(!confirm('本当に削除しますか？')) return;
            await fetch(`/tasks/${id}`, { method: 'DELETE' })
                .finally(() => location.href = "/");
        }
    });

    // テーマ切り替え
    document.getElementById('themeToggle').onclick = () => {
        const current = document.documentElement.getAttribute('data-theme');
        document.documentElement.setAttribute('data-theme', current === 'dark' ? 'light' : 'dark');
    };

    window.onload = renderTreemap;
    window.onresize = renderTreemap;
</script>

</body>
</html>