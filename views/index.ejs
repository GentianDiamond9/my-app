<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>タスク管理 & 高機能ツリーマップビュー</title>
    <style>
        /* --- スタイルテーマ定義 --- */
        :root {
            --bg-color: #f8f9fa;
            --card-bg: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #dee2e6;
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --default-node-color: #64748b; /* 指定なし時の灰色 */
        }

        [data-theme="dark"] {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --default-node-color: #475569;
        }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px;
            transition: background-color 0.3s, color 0.3s;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .theme-toggle-btn {
            background-color: var(--card-bg);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }
        @media(min-width: 768px) {
            .main-container { grid-template-columns: 1fr 1.2fr; }
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        /* --- タスクリスト --- */
        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
        }
        .task-item:last-child { border-bottom: none; }
        .task-info { display: flex; flex-direction: column; gap: 4px; }
        .completed { text-decoration: line-through; color: var(--text-muted); opacity: 0.6; }
        .deadline-text { font-size: 0.85rem; color: var(--text-muted); }

        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
        }
        .btn-success { background-color: var(--success-color); color: white; }
        .btn-warning { background-color: var(--warning-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; margin-left: 6px; }
        
        .badge {
            display: inline-block;
            padding: 2px 6px;
            font-size: 0.75rem;
            border-radius: 4px;
            font-weight: bold;
            margin-right: 6px;
            color: white;
        }
        .badge-3 { background-color: #ef4444; }
        .badge-2 { background-color: #f59e0b; }
        .badge-1 { background-color: #3b82f6; }

        /* タグ用のカスタムバッジ */
        .tag-badge {
            background-color: var(--border-color);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 1px 6px;
            font-size: 0.75rem;
            border-radius: 12px;
            margin-left: 6px;
        }

        /* カラープレビューサークル */
        .color-dot {
            display: inline-block;
            width: 100%;
            height: 4px;
            border-radius: 2px;
            margin-top: 4px;
        }

        /* --- ツリーマップ & オーバーレイ詳細 --- */
        .treemap-wrapper {
            width: 100%;
            height: 500px;
            background-color: var(--bg-color);
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }

        .treemap-node {
            position: absolute;
            box-sizing: border-box;
            border: 1px solid var(--card-bg);
            padding: 6px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            overflow: hidden;
            transition: all 0.2s ease-in-out;
            color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.6);
            cursor: pointer;
        }
        .treemap-node:hover {
            transform: scale(0.99);
            filter: brightness(1.1);
            z-index: 10;
        }

        .node-title { font-weight: bold; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .node-size { opacity: 0.9; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .detail-overlay {
            position: absolute;
            bottom: 12px;
            left: 12px;
            right: 12px;
            background-color: rgba(15, 23, 42, 0.95);
            color: #ffffff;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #334155;
            font-size: 0.9rem;
            display: none;
            z-index: 100;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);
            pointer-events: none;
        }

        form { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
        .form-group { display: flex; flex-direction: column; gap: 4px; }
        .form-row { display: grid; grid-template-columns: 2fr 1fr; gap: 12px; }
        input, select {
            padding: 8px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            background-color: var(--card-bg);
            color: var(--text-color);
        }
        input[type="color"] { padding: 2px; height: 38px; width: 100%; cursor: pointer; }
        .btn-primary { background-color: var(--primary-color); color: white; padding: 10px; font-weight: bold; border: none; border-radius: 6px;}
    </style>
</head>
<body>

    <header>
        <h1>TreeMap Tasks Premium</h1>
        <button class="theme-toggle-btn" id="themeToggle">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <h2>マイ・タスク</h2>
                <div id="taskList">
                    <% if (tasks.length === 0) { %>
                        <p style="color: var(--text-muted);">タスクはまだありません。</p>
                    <% } %>
                    <% 
                        // 重複しない既存のタグ一覧を抽出して、datalist用の配列を作る
                        const existingTags = [...new Set(tasks.map(t => t.tag).filter(Boolean))];
                        tasks.forEach(task => { 
                            const labels = {3: '高', 2: '中', 1: '低'};
                    %>
                        <div class="task-item" id="task-<%= task.id %>">
                            <div class="task-info">
                                <span class="<%= task.is_completed ? 'completed' : '' %>" id="title-<%= task.id %>">
                                    <span class="badge badge-<%= task.importance %>">重要度: <%= labels[task.importance] %></span>
                                    <strong><%= task.title %></strong>
                                    <% if (task.tag) { %>
                                        <span class="tag-badge">🏷️ <%= task.tag %></span>
                                    <% } %>
                                </span>
                                <span class="deadline-text" id="deadline-<%= task.id %>">
                                    ⏳ 期限: <%= new Date(task.deadline).toLocaleDateString() %>
                                </span>
                                <% if (task.color) { %>
                                    <span class="color-dot" style="background-color: <%= task.color %>;"></span>
                                <% } %>
                            </div>
                            <div id="actions-<%= task.id %>">
                                <% if (task.is_completed) { %>
                                    <button class="btn btn-warning toggle-btn" data-id="<%= task.id %>" data-status="false">戻す</button>
                                <% } else { %>
                                    <button class="btn btn-success toggle-btn" data-id="<%= task.id %>" data-status="true">完了</button>
                                <% } %>
                                <button class="btn btn-danger delete-btn" data-id="<%= task.id %>">削除</button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="card">
                <h3>新しいタスクを追加</h3>
                <form action="/tasks" method="POST">
                    <div class="form-group">
                        <label>タイトル</label>
                        <input type="text" name="title" required placeholder="例: システム設計書の作成">
                    </div>
                    <div class="form-group">
                        <label>期限</label>
                        <input type="date" name="deadline" required id="defaultDeadline">
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label>タグ（手入力 または 既存から選択）</label>
                            <input type="text" name="tag" placeholder="例: 仕事, プライベート" list="tagSuggestions" autocomplete="off">
                            <datalist id="tagSuggestions">
                                <% existingTags.forEach(tag => { %>
                                    <option value="<%= tag %>"></option>
                                <% }) %>
                            </datalist>
                        </div>
                        <div class="form-group">
                            <label>カスタム色</label>
                            <input type="color" name="color" value="#64748b">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>重要度</label>
                        <select name="importance">
                            <option value="1">低</option>
                            <option value="2">中</option>
                            <option value="3">高</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">タスク作成</button>
                </form>
            </div>
        </div>

        <div class="card" style="display: flex; flex-direction: column; position: relative;">
            <h2>状況変化マップ</h2>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px;">
                🎨 カスタムカラーのタスクはその色で、指定がないものはすべて「灰色」で統一表示されます。
            </p>
            <div class="treemap-wrapper" id="treemapContainer"></div>
            <div class="detail-overlay" id="detailOverlay"></div>
        </div>
    </div>

    <script>
        let allTasks = <%- JSON.stringify(tasks) %>;
        document.getElementById('defaultDeadline').valueAsDate = new Date();

        // A. テーマ切り替え
        const themeToggle = document.getElementById('themeToggle');
        if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            if (currentTheme === 'dark') {
                document.documentElement.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            }
        });

        // B. イベントリスナーによる一括キャッチ
        document.getElementById('taskList').addEventListener('click', async (e) => {
            if (e.target.classList.contains('toggle-btn')) {
                const id = Number(e.target.getAttribute('data-id'));
                const targetStatus = e.target.getAttribute('data-status') === 'true';
                await toggleTaskStatus(id, targetStatus);
            }
            if (e.target.classList.contains('delete-btn')) {
                const id = Number(e.target.getAttribute('data-id'));
                await deleteTask(id);
            }
        });

        async function toggleTaskStatus(id, targetStatus) {
            try {
                const response = await fetch(`/tasks/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ is_completed: targetStatus })
                });
                if (response.ok) {
                    allTasks = allTasks.map(t => t.id === id ? { ...t, is_completed: targetStatus } : t);
                    const titleEl = document.getElementById(`title-${id}`);
                    const actionsContainer = document.getElementById(`actions-${id}`);
                    
                    if (targetStatus === true) {
                        titleEl.classList.add('completed');
                        actionsContainer.innerHTML = `
                            <button class="btn btn-warning toggle-btn" data-id="${id}" data-status="false">戻す</button>
                            <button class="btn btn-danger delete-btn" data-id="${id}">削除</button>
                        `;
                    } else {
                        titleEl.classList.remove('completed');
                        actionsContainer.innerHTML = `
                            <button class="btn btn-success toggle-btn" data-id="${id}" data-status="true">完了</button>
                            <button class="btn btn-danger delete-btn" data-id="${id}">削除</button>
                        `;
                    }
                    renderTreemap();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteTask(id) {
            if (!confirm("削除しますか？")) return;
            try {
                const response = await fetch(`/tasks/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    document.getElementById(`task-${id}`).remove();
                    allTasks = allTasks.filter(t => t.id !== id);
                    renderTreemap();
                }
            } catch (err) {
                console.error(err);
            }
        }

        // C. アルゴリズム＆レンダリング
        function renderTreemap() {
            const container = document.getElementById('treemapContainer');
            const overlay = document.getElementById('detailOverlay');
            container.innerHTML = '';
            
            const activeTasks = allTasks.filter(t => !t.is_completed);
            if (activeTasks.length === 0) {
                container.innerHTML = '<div style="padding:40px; text-align:center; color:var(--text-muted);">🎉 タスクはすべてクリアされています！</div>';
                overlay.style.display = 'none';
                return;
            }

            const now = new Date();
            const labels = {3: '高', 2: '中', 1: '低'};

            // 新計算式（重要度^2 / 残り日数）
            const scoredTasks = activeTasks.map(task => {
                const deadline = new Date(task.deadline);
                const diffTime = deadline.getTime() - now.getTime();
                let diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                
                const daysDivisor = diffDays <= 0 ? 0.5 : diffDays;
                const weight = Math.pow(task.importance, 2) / daysDivisor;
                return { ...task, weight, diffDays };
            });

            const sorted = scoredTasks.sort((a, b) => b.weight - a.weight);
            const totalWeight = sorted.reduce((sum, t) => sum + t.weight, 0);

            let remainingWidth = container.clientWidth;
            let remainingHeight = container.clientHeight;
            let x = 0, y = 0;

            sorted.forEach((task, index) => {
                const node = document.createElement('div');
                node.className = 'treemap-node';
                
                // 🎨 【変更】color指定があればその色、なければテーマに応じた灰色をセット
                if (task.color && task.color !== '#64748b') {
                    node.style.backgroundColor = task.color;
                } else {
                    node.style.backgroundColor = 'var(--default-node-color)';
                }

                let w, h;
                const currentSliceWeight = sorted.slice(index).reduce((s, t) => s + t.weight, 0);
                const ratio = task.weight / currentSliceWeight;

                if (remainingWidth > remainingHeight) {
                    w = remainingWidth * ratio; h = remainingHeight;
                    node.style.left = `${x}px`; node.style.top = `${y}px`;
                    x += w; remainingWidth -= w;
                } else {
                    w = remainingWidth; h = remainingHeight * ratio;
                    node.style.left = `${x}px`; node.style.top = `${y}px`;
                    y += h; remainingHeight -= h;
                }

                node.style.width = `${w}px`;
                node.style.height = `${h}px`;

                const area = w * h;
                let fontSize = 0.85;
                if (area > 50000) fontSize = 1.3;
                else if (area > 25000) fontSize = 1.1;
                else if (area < 8000) fontSize = 0.65;

                node.style.fontSize = `${fontSize}rem`;

                let dayText = task.diffDays <= 0 ? "🔥 期限直前/超過" : `⏰ あと ${task.diffDays} 日`;
                let tagText = task.tag ? ` [${task.tag}]` : '';

                node.innerHTML = `
                    <div class="node-title">${task.title}${tagText}</div>
                    <div class="node-size" style="font-size: ${fontSize * 0.8}rem;">${dayText}</div>
                `;

                // オーバーレイ表示（タグ情報も追加）
                node.addEventListener('mouseenter', () => {
                    overlay.innerHTML = `
                        <strong>🗂 タスク名:</strong> ${task.title}<br>
                        <strong>🏷️ タグ:</strong> ${task.tag || 'なし'} | 
                        <strong>🚨 重要度:</strong> ${labels[task.importance]} | 
                        <strong>📅 期限:</strong> ${new Date(task.deadline).toLocaleDateString()} (${dayText})<br>
                        <strong>📐 計算ウェイト値:</strong> ${task.weight.toFixed(2)}
                    `;
                    overlay.style.display = 'block';
                });

                node.addEventListener('mouseleave', () => {
                    overlay.style.display = 'none';
                });

                container.appendChild(node);
            });
        }

        window.addEventListener('load', renderTreemap);
        window.addEventListener('resize', renderTreemap);
    </script>
</body>
</html>