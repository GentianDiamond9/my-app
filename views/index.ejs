<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>タスク管理 & 高機能ツリーマップビュー</title>
    <style>
        /* --- 1. スタイルテーマ定義 --- */
        :root {
            --bg-color: #f8f9fa;
            --card-bg: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #dee2e6;
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --importance-3: #fca5a5;
            --importance-2: #fde047;
            --importance-1: #93c5fd;
        }

        [data-theme="dark"] {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --importance-3: #991b1b;
            --importance-2: #854d0e;
            --importance-1: #1e3a8a;
        }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
            transition: background-color 0.3s, color 0.3s;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .theme-toggle-btn {
            background-color: var(--card-bg);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }
        @media(min-width: 768px) {
            .main-container { grid-template-columns: 1fr 1fr; }
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        /* --- 2. タスクリストのスタイル --- */
        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
        }
        .task-item:last-child { border-bottom: none; }
        
        .task-info { display: flex; flex-direction: column; gap: 4px; }
        .completed { text-decoration: line-through; color: var(--text-muted); opacity: 0.6; }
        .deadline-text { font-size: 0.85rem; color: var(--text-muted); }

        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            transition: background-color 0.2s;
        }
        .btn-success { background-color: var(--success-color); color: white; }
        .btn-warning { background-color: var(--warning-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; margin-left: 6px; }
        
        .badge {
            display: inline-block;
            padding: 2px 6px;
            font-size: 0.75rem;
            border-radius: 4px;
            font-weight: bold;
            margin-right: 6px;
        }
        .badge-3 { background-color: #ef4444; color: white; }
        .badge-2 { background-color: #eab308; color: black; }
        .badge-1 { background-color: #3b82f6; color: white; }

        /* --- 3. ツリーマップのスタイル --- */
        .treemap-wrapper {
            width: 100%;
            height: 450px;
            background-color: var(--bg-color);
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }

        .treemap-node {
            position: absolute;
            box-sizing: border-box;
            border: 2px solid var(--card-bg);
            padding: 8px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            overflow: hidden;
            transition: all 0.3s ease-in-out;
            color: #212529;
            font-weight: bold;
        }
        [data-theme="dark"] .treemap-node { color: #ffffff; }

        .treemap-node .node-title { font-size: 0.85rem; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .treemap-node .node-size { font-size: 0.7rem; opacity: 0.8; margin-top: 4px; }

        form { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
        .form-group { display: flex; flex-direction: column; gap: 4px; }
        input, select {
            padding: 8px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            background-color: var(--card-bg);
            color: var(--text-color);
        }
        .btn-primary { background-color: var(--primary-color); color: white; padding: 10px; font-weight: bold; }
    </style>
</head>
<body>

    <header>
        <h1>TreeMap Tasks PRO</h1>
        <button class="theme-toggle-btn" id="themeToggle">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <h2>マイ・タスク</h2>
                <div id="taskList">
                    <% if (tasks.length === 0) { %>
                        <p style="color: var(--text-muted);">タスクはまだありません。</p>
                    <% } %>
                    <% tasks.forEach(task => { %>
                        <div class="task-item" id="task-<%= task.id %>">
                            <div class="task-info">
                                <span class="<%= task.is_completed ? 'completed' : '' %>" id="title-<%= task.id %>">
                                    <span class="badge badge-<%= task.importance %>">重要度: <%= task.importance %></span>
                                    <strong><%= task.title %></strong>
                                </span>
                                <span class="deadline-text" id="deadline-<%= task.id %>">
                                    ⏳ 期限: <%= new Date(task.deadline).toLocaleDateString() %>
                                </span>
                            </div>
                            <div id="actions-<%= task.id %>">
                                <% if (task.is_completed) { %>
                                    <button class="btn btn-warning" onclick="toggleTaskStatus(<%= task.id %>, false)">戻す</button>
                                <% } else { %>
                                    <button class="btn btn-success" onclick="toggleTaskStatus(<%= task.id %>, true)">完了</button>
                                <% } %>
                                <button class="btn btn-danger" onclick="deleteTask(<%= task.id %>)">削除</button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="card">
                <h3>新しいタスクを追加</h3>
                <form action="/tasks" method="POST">
                    <div class="form-group">
                        <label>タイトル</label>
                        <input type="text" name="title" required placeholder="例: 重要タスク">
                    </div>
                    <div class="form-group">
                        <label>期限</label>
                        <input type="date" name="deadline" required id="defaultDeadline">
                    </div>
                    <div class="form-group">
                        <label>重要度</label>
                        <select name="importance">
                            <option value="1">1 (低)</option>
                            <option value="2">2 (中)</option>
                            <option value="3">3 (高)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">タスク作成</button>
                </form>
            </div>
        </div>

        <div class="card" style="display: flex; flex-direction: column;">
            <h2>状況変化マップ</h2>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px;">
                🔥 タイルの面積 ＝ <strong>重要度 ✕ 期限の近さ補正</strong> です。戻したタスクもリアルタイムに再配置されます。
            </p>
            <div class="treemap-wrapper" id="treemapContainer"></div>
        </div>
    </div>

    <script>
        // バックエンドから渡された初期タスク配列
        let allTasks = <%- JSON.stringify(tasks) %>;

        // 今日の日付入力をデフォルトセット
        document.getElementById('defaultDeadline').valueAsDate = new Date();

        // A. テーマ切り替え
        const themeToggle = document.getElementById('themeToggle');
        if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            if (currentTheme === 'dark') {
                document.documentElement.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            }
        });

        // B. 非同期API制御（状態反転に対応）
        async function toggleTaskStatus(id, targetStatus) {
            try {
                const response = await fetch(`/tasks/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ is_completed: targetStatus })
                });
                
                if (response.ok) {
                    // 1. メモリ上のデータを更新
                    allTasks = allTasks.map(t => t.id === id ? { ...t, is_completed: targetStatus } : t);
                    
                    // 2. DOM（見た目）の即座変更
                    const titleEl = document.getElementById(`title-${id}`);
                    const actionsContainer = document.getElementById(`actions-${id}`);
                    
                    if (targetStatus === true) {
                        // 完了状態への変更
                        titleEl.classList.add('completed');
                        // ボタンを「戻す (btn-warning)」に差し替え
                        actionsContainer.innerHTML = `
                            <button class="btn btn-warning" onclick="toggleTaskStatus(${id}, false)">戻す</button>
                            <button class="btn btn-danger" onclick="deleteTask(${id})">削除</button>
                        `;
                    } else {
                        // 未完了状態（戻す）への変更
                        titleEl.classList.remove('completed');
                        // ボタンを「完了 (btn-success)」に差し替え
                        actionsContainer.innerHTML = `
                            <button class="btn btn-success" onclick="toggleTaskStatus(${id}, true)">完了</button>
                            <button class="btn btn-danger" onclick="deleteTask(${id})">削除</button>
                        `;
                    }
                    
                    // 3. ツリーマップを再描画
                    renderTreemap();
                }
            } catch (err) {
                console.error("更新に失敗しました:", err);
            }
        }

        async function deleteTask(id) {
            if (!confirm("このタスクを削除しますか？")) return;
            try {
                const response = await fetch(`/tasks/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    document.getElementById(`task-${id}`).remove();
                    allTasks = allTasks.filter(t => t.id !== id);
                    renderTreemap();
                }
            } catch (err) {
                console.error("削除に失敗しました:", err);
            }
        }

        // C. 動的重み付けツリーマップ描画ロジック
        function renderTreemap() {
            const container = document.getElementById('treemapContainer');
            container.innerHTML = '';
            
            const activeTasks = allTasks.filter(t => !t.is_completed);
            
            if (activeTasks.length === 0) {
                container.innerHTML = '<div style="padding:40px; text-align:center; color:var(--text-muted);">🎉 未完了のタスクはありません！</div>';
                return;
            }

            const now = new Date();

            const scoredTasks = activeTasks.map(task => {
                const deadline = new Date(task.deadline);
                const diffTime = deadline.getTime() - now.getTime();
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                let timeFactor = 1;
                if (diffDays <= 0) timeFactor = 5;
                else if (diffDays <= 3) timeFactor = 3;
                else if (diffDays <= 7) timeFactor = 2;

                const weight = task.importance * timeFactor;
                return { ...task, weight, diffDays };
            });

            const sorted = scoredTasks.sort((a, b) => b.weight - a.weight);
            const totalWeight = sorted.reduce((sum, t) => sum + t.weight, 0);

            let remainingWidth = container.clientWidth;
            let remainingHeight = container.clientHeight;
            let x = 0, y = 0;

            const colors = { 3: 'var(--importance-3)', 2: 'var(--importance-2)', 1: 'var(--importance-1)' };

            sorted.forEach((task, index) => {
                const node = document.createElement('div');
                node.className = 'treemap-node';
                node.style.backgroundColor = colors[task.importance];

                let w, h;
                const currentSliceWeight = sorted.slice(index).reduce((s, t) => s + t.weight, 0);
                const ratio = task.weight / currentSliceWeight;

                if (remainingWidth > remainingHeight) {
                    w = remainingWidth * ratio;
                    h = remainingHeight;
                    node.style.left = `${x}px`;
                    node.style.top = `${y}px`;
                    node.style.width = `${w}px`;
                    node.style.height = `${h}px`;
                    x += w;
                    remainingWidth -= w;
                } else {
                    w = remainingWidth;
                    h = remainingHeight * ratio;
                    node.style.left = `${x}px`;
                    node.style.top = `${y}px`;
                    node.style.width = `${w}px`;
                    node.style.height = `${h}px`;
                    y += h;
                    remainingHeight -= h;
                }

                let dayText = task.diffDays <= 0 ? "🔥 今日！" : `⏰ あと ${task.diffDays} 日`;

                node.innerHTML = `
                    <div class="node-title">${task.title}</div>
                    <div class="node-size">${dayText} (重: ${task.importance})</div>
                `;
                container.appendChild(node);
            });
        }

        window.addEventListener('load', renderTreemap);
        window.addEventListener('resize', renderTreemap);
    </script>
</body>
</html>