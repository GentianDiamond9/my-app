<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>タスク管理アプリ</title>
    <style>
        body { font-family: sans-serif; max-width: 600px; margin: 20px auto; padding: 20px; }
        .task-item { border-bottom: 1px solid #ccc; padding: 10px; display: flex; justify-content: space-between; align-items: center; }
        .completed { text-decoration: line-through; color: gray; }
        .importance-3 { border-left: 5px solid red; }
        .importance-2 { border-left: 5px solid orange; }
        .importance-1 { border-left: 5px solid blue; }
        form { margin-top: 20px; background: #f4f4f4; padding: 15px; border-radius: 8px; }
    </style>
</head>
<body>
    <h1>マイ・タスク</h1>
    <div id="taskList">
        <% tasks.forEach(task => { %>
            <div class="task-item importance-<%= task.importance %>">
                <div>
                    <span class="<%= task.is_completed ? 'completed' : '' %>">
                        <strong><%= task.title %></strong> 
                        (期限: <%= new Date(task.deadline).toLocaleDateString() %>)
                    </span>
                </div>
                <div>
                    <!-- 完了・削除ボタンなどはここに追加できるぞ -->
                </div>
            </div>
        <% }) %>
    </div>

    <form action="/tasks" method="POST">
        <h3>新しいタスクを追加</h3>
        <div>タイトル: <input type="text" name="title" required></div>
        <div>期限: <input type="date" name="deadline" required></div>
        <div>重要度 (1-3): <input type="number" name="importance" min="1" max="3" value="1"></div>
        <button type="submit">タスク作成</button>
    </form>
</body>
</html>