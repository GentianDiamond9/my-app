<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TreeMap Tasks Premium</title>
    <style>
        /* --- スタイル（お主のデザインを継承） --- */
        :root {
            --bg-color: #f8f9fa; --card-bg: #ffffff; --text-color: #212529; --text-muted: #6c757d;
            --border-color: #dee2e6; --primary-color: #4f46e5; --success-color: #10b981;
            --warning-color: #f59e0b; --danger-color: #ef4444; --default-node-color: #64748b;
        }
        [data-theme="dark"] {
            --bg-color: #0f172a; --card-bg: #1e293b; --text-color: #f8fafc;
            --text-muted: #94a3b8; --border-color: #334155; --primary-color: #6366f1;
        }
        body { font-family: sans-serif; background-color: var(--bg-color); color: var(--text-color); max-width: 1200px; margin: 0 auto; padding: 20px; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .main-container { display: grid; grid-template-columns: 1fr; gap: 24px; }
        @media(min-width: 768px) { .main-container { grid-template-columns: 1fr 1.5fr; } }
        .card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; margin-bottom: 24px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .task-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid var(--border-color); }
        .completed { text-decoration: line-through; opacity: 0.5; }
        .badge { padding: 2px 6px; font-size: 0.75rem; border-radius: 4px; color: white; margin-right: 5px; }
        .badge-3 { background-color: var(--danger-color); }
        .badge-2 { background-color: var(--warning-color); }
        .badge-1 { background-color: var(--primary-color); }
        .treemap-wrapper { width: 100%; height: 500px; background: var(--bg-color); border-radius: 8px; position: relative; overflow: hidden; border: 1px solid var(--border-color); }
        .treemap-node { position: absolute; box-sizing: border-box; border: 1px solid var(--card-bg); display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; cursor: pointer; transition: 0.2s; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); }
        .treemap-node:hover { transform: scale(0.98); filter: brightness(1.1); }
        form { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
        input, select, button { padding: 8px; border-radius: 6px; border: 1px solid var(--border-color); }
        .btn-primary { background: var(--primary-color); color: white; font-weight: bold; cursor: pointer; }
        .stat-val { font-size: 1.8rem; font-weight: bold; color: var(--primary-color); }
    </style>
</head>
<body>
    <header>
        <h1>TreeMap Tasks Premium</h1>
        <button id="themeToggle" style="cursor:pointer; border-radius:20px; padding:5px 15px;">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <!-- 左カラム: リストと統計 -->
        <div class="left-col">
            <div class="card">
                <h2>タスクの一覧</h2>
                <div id="taskList">
                    <% tasks.forEach(task => { %>
                        <div class="task-item">
                            <div>
                                <div class="<%= task.is_completed ? 'completed' : '' %>">
                                    <span class="badge badge-<%= task.importance %>">重:<%= task.importance %></span>
                                    <strong><%= task.title %></strong>
                                </div>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">
                                    ⏳ <%= new Date(task.deadline).toLocaleString() %>
                                </div>
                            </div>
                            <div>
                                <button class="toggle-btn" data-id="<%= task.id %>" data-status="<%= !task.is_completed %>" style="cursor:pointer;">
                                    <%= task.is_completed ? '戻す' : '完了' %>
                                </button>
                                <button class="delete-btn" data-id="<%= task.id %>" style="background:var(--danger-color); color:white; border:none; cursor:pointer;">削除</button>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <form action="/tasks" method="POST">
                    <input type="text" name="title" placeholder="新しいタスクを入力" required>
                    <div style="display: flex; gap: 10px;">
                        <input type="datetime-local" name="deadline" style="flex: 2;" required>
                        <select name="importance" style="flex: 1;">
                            <option value="3">重要度: 高</option>
                            <option value="2">重要度: 中</option>
                            <option value="1">重要度: 低</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-primary">タスクを追加</button>
                </form>
            </div>

            <div class="card">
                <h2>期限内達成率</h2>
                <div style="display: flex; justify-content: space-around; text-align: center;">
                    <div><div style="font-size: 0.8rem;">過去1週間</div><div class="stat-val"><%= stats.weekRate %>%</div></div>
                    <div><div style="font-size: 0.8rem;">過去1か月</div><div class="stat-val"><%= stats.monthRate %>%</div></div>
                </div>
            </div>
        </div>

        <!-- 右カラム: マップ -->
        <div class="right-col">
            <div class="card">
                <h2>重要度マップ</h2>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px;">
                    優先度が高いタスクほど大きく表示されます！
                </p>
                <div id="treemap" class="treemap-wrapper"></div>
            </div>
        </div>
    </div>

    <script>
        const tasks = <%- JSON.stringify(tasks) %>;
        const container = document.getElementById('treemap');

        function renderTreemap() {
            container.innerHTML = '';
            const pending = tasks.filter(t => !t.is_completed);
            if (!pending.length) return;

            const now = new Date();
            const nodes = pending.map(t => {
                const deadline = new Date(t.deadline);
                const overdueDays = Math.max(0, (now - deadline) / (1000 * 60 * 60 * 24));
                // 面積: 重要度 * (1 + 超過日数)
                const value = t.importance * (1 + overdueDays);
                return { ...t, value };
            });

            const total = nodes.reduce((s, n) => s + n.value, 0);
            let curX = 0;
            nodes.forEach(n => {
                const w = (n.value / total) * container.offsetWidth;
                const div = document.createElement('div');
                div.className = 'treemap-node';
                div.style.left = `${curX}px`; div.style.width = `${w}px`; div.style.height = '100%';
                div.style.backgroundColor = n.color || 'var(--primary-color)';
                div.innerHTML = `<div style="font-weight:bold;">${n.title}</div><div style="font-size:0.7rem;">${Math.round(n.value * 10)/10}pt</div>`;
                container.appendChild(div);
                curX += w;
            });
        }

        document.addEventListener('click', async (e) => {
            const id = e.target.dataset.id;
            if (e.target.classList.contains('toggle-btn')) {
                const is_completed = e.target.dataset.status === 'true';
                await fetch(`/tasks/${id}`, {
                    method: 'PATCH', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ is_completed })
                }).finally(() => location.href = "/");
            }
            if (e.target.classList.contains('delete-btn')) {
                if(confirm('削除しますか？')) {
                    await fetch(`/tasks/${id}`, { method: 'DELETE' }).finally(() => location.href = "/");
                }
            }
        });

        document.getElementById('themeToggle').onclick = () => {
            const html = document.documentElement;
            html.setAttribute('data-theme', html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        };

        window.onload = renderTreemap;
        window.onresize = renderTreemap;
    </script>
</body>
</html>
