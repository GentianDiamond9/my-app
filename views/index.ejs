<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8"><title>TreeMap Tasks Ultimate</title>
    <style>
        /* --- スタイル継承 & 追加 --- */
        :root { --bg: #f8f9fa; --card: #ffffff; --text: #212529; --primary: #4f46e5; --danger: #ef4444; }
        [data-theme="dark"] { --bg: #0f172a; --card: #1e293b; --text: #f8fafc; }
        body { font-family: sans-serif; background: var(--bg); color: var(--text); max-width: 1200px; margin: 0 auto; padding: 20px; }
        .main-container { display: grid; grid-template-columns: 1fr; gap: 24px; }
        @media(min-width: 768px) { .main-container { grid-template-columns: 1fr 1.5fr; } }
        .card { background: var(--card); border: 1px solid #dee2e6; border-radius: 12px; padding: 20px; margin-bottom: 24px; }
        .treemap-wrapper { width: 100%; height: 500px; background: #eee; border-radius: 8px; position: relative; overflow: hidden; }
        .treemap-node { position: absolute; box-sizing: border-box; border: 2px solid var(--card); display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; cursor: pointer; transition: transform 0.2s; text-shadow: 1px 1px 3px rgba(0,0,0,0.7); overflow: hidden; }
        
        /* 弾け飛ぶパーティクルのスタイル */
        .particle { position: fixed; pointer-events: none; z-index: 9999; border-radius: 2px; animation: fly 0.8s ease-out forwards; }
        @keyframes fly {
            to { transform: translate(var(--dx), var(--dy)) rotate(360deg); opacity: 0; }
        }

        .tag-history-item { cursor: pointer; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem; border: 1px solid #ddd; margin: 2px; display: inline-block; }
        input, select { margin-bottom: 8px; padding: 8px; border-radius: 6px; border: 1px solid #ddd; }
    </style>
</head>
<body>
    <header style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h1>TreeMap Ultimate 🚀</h1>
        <button id="themeToggle">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <div class="left-col">
            <div class="card">
                <h2>タスク管理</h2>
                <div id="taskList">
                    <% tasks.forEach(task => { %>
                        <div style="display:flex; justify-content:space-between; padding:10px; border-bottom:1px solid #eee;">
                            <div class="<%= task.is_completed ? 'completed' : '' %>">
                                <strong><%= task.title %></strong>
                                <% if(task.tag) { %><span style="font-size:0.7rem; background:#eee; padding:2px 6px; border-radius:10px; color:#333; margin-left:5px;">🏷️ <%= task.tag %></span><% } %>
                                <div style="font-size:0.7rem; color:gray;">⏳ <%= new Date(task.deadline).toLocaleString() %></div>
                            </div>
                            <div>
                                <button class="toggle-btn" data-id="<%= task.id %>" data-status="<%= !task.is_completed %>" data-importance="<%= task.importance %>">
                                    <%= task.is_completed ? '戻す' : '完了' %>
                                </button>
                                <button class="delete-btn" data-id="<%= task.id %>" style="color:red;">削除</button>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <form action="/tasks" method="POST" style="display:flex; flex-direction:column; margin-top:20px;">
                    <input type="text" name="title" placeholder="タスク名" required>
                    <input type="datetime-local" name="deadline" required>
                    <select name="importance">
                        <option value="3">重要度: 高</option><option value="2">重要度: 中</option><option value="1">重要度: 低</option>
                    </select>
                    <div id="tagHistory" style="margin-bottom:8px;">
                        <!-- JSで最近のタグを表示 -->
                    </div>
                    <div style="display:flex; gap:10px;">
                        <input type="text" id="tagInput" name="tag" placeholder="タグ" style="flex:2;">
                        <input type="color" id="colorInput" name="color" value="#4f46e5" style="flex:1; height:40px;">
                    </div>
                    <button type="submit" style="background:#4f46e5; color:white; font-weight:bold; cursor:pointer;">追加</button>
                </form>
            </div>

            <div class="card">
                <h2>達成率</h2>
                <div style="display:flex; justify-content:space-around; text-align:center;">
                    <div>週: <%= stats.weekRate %>%</div><div>月: <%= stats.monthRate %>%</div>
                </div>
            </div>
        </div>

        <div class="right-col">
            <div class="card">
                <h2>重要度マップ</h2>
                <div id="treemap" class="treemap-wrapper"></div>
            </div>
        </div>
    </div>

    <script>
        const tasks = <%- JSON.stringify(tasks) %>;
        const container = document.getElementById('treemap');

        // タグ履歴の生成
        const tagHistory = document.getElementById('tagHistory');
        const uniqueTags = [];
        tasks.forEach(t => {
            if(t.tag && !uniqueTags.find(x => x.tag === t.tag)) uniqueTags.push({tag: t.tag, color: t.color});
        });
        uniqueTags.slice(-5).forEach(item => {
            const span = document.createElement('span');
            span.className = 'tag-history-item';
            span.style.borderColor = item.color;
            span.innerText = item.tag;
            span.onclick = () => {
                document.getElementById('tagInput').value = item.tag;
                document.getElementById('colorInput').value = item.color || '#4f46e5';
            };
            tagHistory.appendChild(span);
        });

        function renderTreemap() {
            container.innerHTML = '';
            const pending = tasks.filter(t => !t.is_completed);
            const now = new Date();
            const nodes = pending.map(t => {
                const overdueDays = Math.max(0, (now - new Date(t.deadline)) / (1000*60*60*24));
                const value = t.importance * (1 + overdueDays);
                return { ...t, value };
            });
            const total = nodes.reduce((s, n) => s + n.value, 0);
            let curX = 0;
            nodes.forEach(n => {
                const w = (n.value / total) * container.offsetWidth;
                const div = document.createElement('div');
                div.className = 'treemap-node';
                div.id = `node-${n.id}`;
                div.style.left = `${curX}px`; div.style.width = `${w}px`; div.style.height = '100%';
                div.style.backgroundColor = n.color || '#4f46e5';
                
                // 面積に応じたフォントサイズ計算
                const fontSize = Math.max(10, Math.min(w / 10, 24));
                div.innerHTML = `
                    <div style="font-weight:bold; font-size:${fontSize}px;">${n.title}</div>
                    <div style="font-size:${fontSize*0.6}px;">${new Date(n.deadline).toLocaleDateString()}</div>
                `;
                container.appendChild(div);
                curX += w;
            });
        }

        // 弾け飛ぶ演出
        function createBurst(x, y, color) {
            for (let i = 0; i < 30; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = x + 'px'; p.style.top = y + 'px';
                p.style.width = Math.random() * 10 + 5 + 'px';
                p.style.height = p.style.width;
                p.style.background = color;
                p.style.setProperty('--dx', (Math.random() - 0.5) * 400 + 'px');
                p.style.setProperty('--dy', (Math.random() - 0.5) * 400 + 'px');
                document.body.appendChild(p);
                setTimeout(() => p.remove(), 1000);
            }
        }

        document.addEventListener('click', async (e) => {
            const btn = e.target;
            const id = btn.dataset.id;
            if (btn.classList.contains('toggle-btn')) {
                const is_completed = btn.dataset.status === 'true';
                const importance = parseInt(btn.dataset.importance);

                if (!is_completed && !confirm('完了したタスクを復活させますか？')) return;

                if (is_completed && importance >= 2) {
                    const node = document.getElementById(`node-${id}`);
                    if (node) {
                        const rect = node.getBoundingClientRect();
                        createBurst(rect.left + rect.width/2, rect.top + rect.height/2, node.style.backgroundColor);
                    }
                }

                await fetch(`/tasks/${id}`, {
                    method: 'PATCH', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ is_completed })
                }).finally(() => setTimeout(() => location.href = "/", 500));
            }
            if (btn.classList.contains('delete-btn')) {
                if(confirm('削除しますか？')) await fetch(`/tasks/${id}`, { method: 'DELETE' }).finally(() => location.href = "/");
            }
        });

        window.onload = renderTreemap;
        window.onresize = renderTreemap;
    </script>
</body>
</html>
