<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>タスク管理 & 高機能ツリーマップビュー</title>
    <style>
        /* --- 1. スタイルテーマ定義 --- */
        :root {
            --bg-color: #f8f9fa;
            --card-bg: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #dee2e6;
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --success-color: #10b981;
            --danger-color: #ef4444;
            --importance-3: #fca5a5;
            --importance-2: #fde047;
            --importance-1: #93c5fd;
        }

        [data-theme="dark"] {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --importance-3: #991b1b;
            --importance-2: #854d0e;
            --importance-1: #1e3a8a;
        }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
            transition: background-color 0.3s, color 0.3s;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .theme-toggle-btn {
            background-color: var(--card-bg);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }
        @media(min-width: 768px) {
            .main-container { grid-template-columns: 1fr 1fr; }
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        /* --- 2. タスクリストのスタイル --- */
        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
        }
        .task-item:last-child { border-bottom: none; }
        
        .task-info { display: flex; flex-direction: column; gap: 4px; }
        .completed { text-decoration: line-through; color: var(--text-muted); opacity: 0.6; }
        .deadline-text { font-size: 0.85rem; color: var(--text-muted); }
        .urgent { color: #ef4444; font-weight: bold; }

        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
        }
        .btn-success { background-color: var(--success-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; margin-left: 6px; }
        
        .badge {
            display: inline-block;
            padding: 2px 6px;
            font-size: 0.75rem;
            border-radius: 4px;
            font-weight: bold;
            margin-right: 6px;
        }
        .badge-3 { background-color: #ef4444; color: white; }
        .badge-2 { background-color: #eab308; color: black; }
        .badge-1 { background-color: #3b82f6; color: white; }

        /* --- 3. ツリーマップのスタイル --- */
        .treemap-wrapper {
            width: 100%;
            height: 450px;
            background-color: var(--bg-color);
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            position: relative;
            overflow: hidden;
        }

        .treemap-node {
            position: absolute;
            box-sizing: border-box;
            border: 2px solid var(--card-bg);
            padding: 8px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            overflow: hidden;
            transition: all 0.3s ease-in-out;
            color: #212529;
            font-weight: bold;
        }
        [data-theme="dark"] .treemap-node { color: #ffffff; }

        .treemap-node .node-title { font-size: 0.85rem; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .treemap-node .node-size { font-size: 0.7rem; opacity: 0.8; margin-top: 4px; }

        form { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
        .form-group { display: flex; flex-direction: column; gap: 4px; }
        input, select {
            padding: 8px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            background-color: var(--card-bg);
            color: var(--text-color);
        }
        .btn-primary { background-color: var(--primary-color); color: white; padding: 10px; font-weight: bold; }
    </style>
</head>
<body>

    <header>
        <h1>TreeMap Tasks PRO</h1>
        <button class="theme-toggle-btn" id="themeToggle">🌓 テーマ切り替え</button>
    </header>

    <div class="main-container">
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <div class="card">
                <h2>マイ・タスク</h2>
                <div id="taskList">
                    <% if (tasks.length === 0) { %>
                        <p style="color: var(--text-muted);">タスクはまだありません。</p>
                    <% } %>
                    <% tasks.forEach(task => { %>
                        <div class="task-item" id="task-<%= task.id %>">
                            <div class="task-info">
                                <span class="<%= task.is_completed ? 'completed' : '' %>" id="title-<%= task.id %>">
                                    <span class="badge badge-<%= task.importance %>">重要度: <%= task.importance %></span>
                                    <strong><%= task.title %></strong>
                                </span>
                                <span class="deadline-text" id="deadline-<%= task.id %>">
                                    ⏳ 期限: <%= new Date(task.deadline).toLocaleDateString() %>
                                </span>
                            </div>
                            <div id="actions-<%= task.id %>">
                                <% if (!task.is_completed) { %>
                                    <button class="btn btn-success" onclick="toggleComplete(<%= task.id %>)">完了</button>
                                <% } %>
                                <button class="btn btn-danger